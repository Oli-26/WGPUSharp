<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <!-- NuGet package metadata -->
    <PackageId>WgpuSharp</PackageId>
    <Version>0.5.0-alpha</Version>
    <Title>WgpuSharp — WebGPU Game Engine for Blazor WASM</Title>
    <Description>A C# game engine and scene editor for the browser via Blazor WebAssembly and WebGPU. Includes scene graph, transform hierarchy, orbit/FPS cameras, translate/rotate/scale gizmos, point lights, procedural sky, collision/gravity/jumping, mesh loading (OBJ/GLB/STL) with automatic LOD generation, skeletal animation (rigged GLB with joint skinning and keyframe playback), per-object scripting, 13 gameplay tags, undo/redo, scene serialization, and batched instanced rendering.</Description>
    <Authors>WgpuSharp Contributors</Authors>
    <PackageTags>webgpu;blazor;wasm;gpu;graphics;3d;compute;shader;rendering</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/Oli-26/WGPUSharp</RepositoryUrl>
    <PackageProjectUrl>https://github.com/Oli-26/WGPUSharp</PackageProjectUrl>
    <PackageIcon>icon.png</PackageIcon>

    <!-- Source Link -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="8.0.24" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
    <InternalsVisibleTo Include="WgpuSharp.Tests" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" />
    <None Include="../../icon.png" Pack="true" PackagePath="/" />
    <None Include="build/WgpuSharp.targets" Pack="true" PackagePath="build/" />
    <None Include="build/WgpuSharp.targets" Pack="true" PackagePath="buildTransitive/" />
  </ItemGroup>

</Project>
