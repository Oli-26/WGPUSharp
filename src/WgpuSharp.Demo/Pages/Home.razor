@page "/"

<PageTitle>WgpuSharp — WebGPU for Blazor</PageTitle>

<div style="max-width: 900px;">
    <h2 style="margin-bottom: 4px;">WgpuSharp</h2>
    <p style="color: #888; font-size: 1.1em; margin-top: 0;">WebGPU for Blazor WASM — typed, async, zero JavaScript required.</p>

    <div style="background: #151520; border: 1px solid #333; border-radius: 8px; padding: 16px 20px; margin-bottom: 20px;">
<pre style="margin: 0; font-size: 0.85em; color: #cdd6f4; overflow-x: auto;"><span style="color:#89b4fa;">var</span> adapter = <span style="color:#89b4fa;">await</span> Gpu.RequestAdapterAsync(JS);
<span style="color:#89b4fa;">var</span> device  = <span style="color:#89b4fa;">await</span> adapter.RequestDeviceAsync();
<span style="color:#89b4fa;">var</span> canvas  = <span style="color:#89b4fa;">await</span> GpuCanvas.ConfigureAsync(device, <span style="color:#a6e3a1;">"my-canvas"</span>);

<span style="color:#6c7086;">// Create shaders, buffers, pipelines... then render:</span>
<span style="color:#89b4fa;">var</span> batch = <span style="color:#89b4fa;">new</span> RenderBatch(device);
batch.WriteBuffer(uniformBuffer, mvpBytes);
<span style="color:#89b4fa;">var</span> view = batch.GetCurrentTextureView(canvas);
<span style="color:#89b4fa;">var</span> pass = batch.BeginRenderPass(view, clearColor, depthView);
pass.SetPipeline(pipeline);
pass.DrawIndexed(indexCount);
pass.EndAndSubmit();
<span style="color:#89b4fa;">await</span> batch.FlushAsync(); <span style="color:#6c7086;">// entire frame in 1 JS call</span></pre>
    </div>

    <h4 style="margin-bottom: 12px;">Demos</h4>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px; margin-bottom: 24px;">
        <a href="/triangle" style="text-decoration: none;">
            <div class="demo-card">
                <strong>Triangle</strong>
                <span>Hello World — vertex buffer, render pipeline, single draw call</span>
            </div>
        </a>
        <a href="/cube" style="text-decoration: none;">
            <div class="demo-card">
                <strong>Spinning Cube</strong>
                <span>Index buffers, uniform MVP matrix, depth buffer, game loop</span>
            </div>
        </a>
        <a href="/reaction-diffusion" style="text-decoration: none;">
            <div class="demo-card">
                <strong>Reaction-Diffusion</strong>
                <span>GPU compute shaders, storage buffers, ping-pong simulation</span>
            </div>
        </a>
        <a href="/mesh-viewer" style="text-decoration: none;">
            <div class="demo-card">
                <strong>Mesh Viewer</strong>
                <span>Load .obj / .glb / .stl — PBR materials, textures, auto-UV</span>
            </div>
        </a>
        <a href="/fly" style="text-decoration: none;">
            <div class="demo-card">
                <strong>Fly Camera</strong>
                <span>WASD + mouse look, 1,728 instanced cubes, pointer lock</span>
            </div>
        </a>
        <a href="/shader-playground" style="text-decoration: none;">
            <div class="demo-card" style="border-color: #3b82f6;">
                <strong style="color: #58a6ff;">Shader Playground</strong>
                <span>Interactive WGSL editor, 28 templates, live preview, save/load</span>
            </div>
        </a>
    </div>

    <h4>Features</h4>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 8px 16px; margin-bottom: 24px; font-size: 0.9em;">
        <div><span style="color: #a6e3a1;">+</span> Render pipelines & shaders</div>
        <div><span style="color: #a6e3a1;">+</span> Compute shaders (GPGPU)</div>
        <div><span style="color: #a6e3a1;">+</span> Vertex, index, uniform buffers</div>
        <div><span style="color: #a6e3a1;">+</span> Textures, samplers, materials</div>
        <div><span style="color: #a6e3a1;">+</span> Depth buffer & culling</div>
        <div><span style="color: #a6e3a1;">+</span> Instanced rendering</div>
        <div><span style="color: #a6e3a1;">+</span> Mesh loading (OBJ/GLB/STL)</div>
        <div><span style="color: #a6e3a1;">+</span> PBR materials & textures</div>
        <div><span style="color: #a6e3a1;">+</span> Keyboard & mouse input</div>
        <div><span style="color: #a6e3a1;">+</span> Batched commands (1 JS call/frame)</div>
        <div><span style="color: #a6e3a1;">+</span> Per-frame handle cleanup</div>
        <div><span style="color: #a6e3a1;">+</span> Type-safe enums (zero magic strings)</div>
        <div><span style="color: #a6e3a1;">+</span> IAsyncDisposable on all resources</div>
        <div><span style="color: #a6e3a1;">+</span> Full XML IntelliSense docs</div>
        <div><span style="color: #a6e3a1;">+</span> Input validation & clear errors</div>
        <div><span style="color: #a6e3a1;">+</span> MIT licensed, NuGet ready</div>
    </div>

    <h4>Quick Start</h4>
    <ol style="font-size: 0.9em; line-height: 1.8;">
        <li>Add to your Blazor WASM project: <code>dotnet add package WgpuSharp</code></li>
        <li>Add to <code>index.html</code>: <code>&lt;script src="_content/WgpuSharp/WgpuSharp.js"&gt;&lt;/script&gt;</code></li>
        <li>Inject <code>@@inject IJSRuntime JS</code> and call <code>Gpu.RequestAdapterAsync(JS)</code></li>
    </ol>

    <p style="font-size: 0.85em; color: #666; margin-top: 24px;">
        WgpuSharp 0.1.0-alpha
        &mdash; Requires Chrome/Edge with WebGPU enabled
        &mdash; <a href="https://github.com" style="color: #58a6ff;">GitHub</a>
    </p>
</div>

