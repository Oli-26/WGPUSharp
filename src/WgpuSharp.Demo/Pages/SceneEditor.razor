        <div class="build-metadata">
            <div class="build-meta-row">
                <label>App Name</label>
                <input type="text" class="build-meta-input" @bind="_pkgName" placeholder="My Game" />
            </div>
            <div class="build-meta-row">
                <label>Version</label>
                <input type="text" class="build-meta-input" @bind="_pkgVersion" placeholder="1.0.0" />
            </div>
            <div class="build-meta-row">
                <label>Author</label>
                <input type="text" class="build-meta-input" @bind="_pkgAuthor" placeholder="Your Name" />
            </div>
            <div class="build-meta-row">
                <label>Email</label>
                <input type="text" class="build-meta-input" @bind="_pkgAuthorEmail" placeholder="you@example.com" />
            </div>
            <div class="build-meta-row">
