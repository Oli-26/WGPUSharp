@page "/editor"
@using System.Numerics
@using WgpuSharp.Core
@using WgpuSharp.Commands
@using WgpuSharp.Mesh
@using WgpuSharp.Pipeline
@using WgpuSharp.Resources
@using WgpuSharp.Scene
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>WgpuSharp — Scene Editor</PageTitle>

<div class="editor-root">
    @* --- Left: Scene hierarchy --- *@
    <div class="editor-sidebar @(_playMode ? "panel-dimmed" : "")">
        <div class="sidebar-header">
            <strong>Scene</strong>
        </div>
        <div class="sidebar-content">
            @foreach (var (node, depth) in GetFlatHierarchy())
            {
                var n = node; // capture for lambda
                bool isSelected = IsSelected(n.Id);
                <div class="hierarchy-node @(isSelected ? "selected" : "") @(_dragNodeId == n.Id ? "dragging" : "")"
                     style="padding-left: @(8 + depth * 16)px"
                     draggable="true"
                     @ondragstart="() => _dragNodeId = n.Id"
                     @ondragover:preventDefault="true"
                     @ondrop="() => ReparentNode(n)"
                     @ondragend="() => _dragNodeId = null"
                     @onclick="e => { if (e.ShiftKey) ToggleSelect(n); else SelectSingle(n); }">
                    <span class="@(n.Visible ? "" : "text-muted")">@n.Name</span>
                </div>
            }
            <div class="hierarchy-node" style="padding: 4px 8px; color: #555; font-style: italic;"
                 @ondragover:preventDefault="true" @ondrop="ReparentToRoot">(drop here for root)</div>
        </div>
        <div class="sidebar-actions">
            <button class="btn btn-sm btn-outline-light" @onclick="() => AddPrimitive(PrimitiveType.Cube)">+ Cube</button>
            <button class="btn btn-sm btn-outline-light" @onclick="() => AddPrimitive(PrimitiveType.Sphere)">+ Sphere</button>
            <button class="btn btn-sm btn-outline-light" @onclick="() => AddPrimitive(PrimitiveType.Plane)">+ Plane</button>
            <button class="btn btn-sm btn-outline-light" @onclick="() => AddPrimitive(PrimitiveType.Cylinder)">+ Cylinder</button>
            <button class="btn btn-sm btn-outline-warning" @onclick="AddLight">+ Light</button>
            <button class="btn btn-sm btn-outline-info" @onclick="ImportMesh">Import</button>
        </div>
        <div class="sidebar-actions" style="border-top: 1px solid #2a2a3a;">
            <button class="btn btn-sm btn-outline-secondary" @onclick="SaveScene">Save</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="LoadScene">Load</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="TakeScreenshot">Screenshot</button>
        </div>
        <div class="sidebar-actions" style="border-top: 1px solid #2a2a3a;">
            <select class="snap-select" style="width: 80px;" @bind="_selectedTemplate">
                @foreach (var t in SceneTemplates)
                {
                    <option value="@t">@t</option>
                }
            </select>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => LoadTemplate(_selectedTemplate)">New Scene</button>
        </div>
    </div>

    @* --- Center: Viewport --- *@
    <div class="editor-viewport">
        @if (_error is not null)
        {
            <div class="alert alert-danger m-2">@_error</div>
        }
        <div class="viewport-toolbar @(_playMode ? "play-toolbar" : "")">
            @if (!_playMode)
            {
                <span class="toolbar-buttons">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => _undo.Undo()" disabled="@(!_undo.CanUndo)" title="@(_undo.UndoDescription ?? "Nothing to undo")">Undo</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => _undo.Redo()" disabled="@(!_undo.CanRedo)" title="@(_undo.RedoDescription ?? "Nothing to redo")">Redo</button>
                </span>
                <span class="toolbar-buttons tool-group">
                    <button class="btn btn-sm @(GizmoModeIs(GizmoMode.Translate) ? "btn-tool-on" : "btn-outline-secondary")"
                            @onclick="() => SetGizmoMode(GizmoMode.Translate)" title="Move tool (W)">Move</button>
                    <button class="btn btn-sm @(GizmoModeIs(GizmoMode.Rotate) ? "btn-tool-on" : "btn-outline-secondary")"
                            @onclick="() => SetGizmoMode(GizmoMode.Rotate)" title="Rotate tool (E)">Rotate</button>
                    <button class="btn btn-sm @(GizmoModeIs(GizmoMode.Scale) ? "btn-tool-on" : "btn-outline-secondary")"
                            @onclick="() => SetGizmoMode(GizmoMode.Scale)" title="Scale tool (R)">Scale</button>
                </span>
                <span class="toolbar-buttons snap-group">
                    <button class="btn btn-sm @(_snapEnabled ? "btn-snap-on" : "btn-outline-secondary")"
                            @onclick="() => _snapEnabled = !_snapEnabled"
                            title="Toggle grid snap (G)">Snap</button>
                    <select class="snap-select" @bind="_snapSize" title="Snap grid size">
                        @foreach (var s in SnapPresets)
                        {
                            <option value="@s">@s.ToString("G")</option>
                        }
                    </select>
                </span>
                <button class="btn btn-sm @(GroundEnabled() ? "btn-snap-on" : "btn-outline-secondary")"
                        @onclick="ToggleGround" title="Toggle ground plane">Floor</button>
                <button class="btn btn-sm btn-play" @onclick="EnterPlayMode">Play</button>
                <span class="text-muted small">
                    @if (_fps > 0) { <text>@_fps.ToString("F0") FPS</text> }
                    | W/E/R=tool  G=snap  Ctrl+Z/Y  Del  Ctrl+D  F=focus
                </span>
            }
            else
            {
                <button class="btn btn-sm btn-stop" @onclick="ExitPlayMode">Stop</button>
                <span class="play-label">PLAYING</span>
                <span class="text-muted small">
                    @if (_fps > 0) { <text>@_fps.ToString("F0") FPS</text> }
                    | WASD=move  Mouse=look  Space=jump  Scroll=speed  Esc=stop
                </span>
            }
        </div>
        <div style="position: relative;">
            <canvas id="gpu-canvas" width="800" height="600"
                    style="display: block; width: 100%; height: calc(100vh - 3.5rem - 28px); cursor: crosshair;"></canvas>
            @if (_playMode && _totalCollectibles > 0)
            {
                <div class="play-hud">
                    <span class="hud-score">@_score / @_totalCollectibles</span>
                    @if (_score >= _totalCollectibles)
                    {
                        <span class="hud-win">ALL COLLECTED!</span>
                    }
                </div>
            }
            @if (_playMode && _triggerMessage is not null)
            {
                <div class="trigger-message">@_triggerMessage</div>
            }
            @if (_playMode && _hasEnemies)
            {
                <div class="health-bar">
                    <div class="health-fill" style="width: @(_playerHealth)%"></div>
                    <span class="health-text">@_playerHealth HP</span>
                </div>
                @if (_playerHealth <= 0)
                {
                    <div class="game-over">GAME OVER</div>
                }
            }
            @if (_playMode)
            {
                <canvas id="minimap-canvas" width="150" height="150" style="position: absolute; bottom: 50px; right: 10px; border: 1px solid #444; border-radius: 4px; pointer-events: none; z-index: 10; background: rgba(0,0,0,0.5);"></canvas>
            }
            @if (_playMode && _timerEnabled)
            {
                <div class="timer-hud">@TimeSpan.FromSeconds(Math.Max(0, _levelTimer)).ToString(@"m\:ss")</div>
            }
            @if (_importing)
            {
                <div class="import-overlay">
                    <div class="import-dialog">
                        <div class="import-title">Importing Model</div>
                        <div class="import-phase" id="import-progress-label">@(_importPhase ?? "Working...")</div>
                        <div class="import-bar-track">
                            <div class="import-bar-fill" id="import-progress-bar" style="width: @(_importPercent)%"></div>
                        </div>
                    </div>
                </div>
            }
            @if (_showStats)
            {
                <div class="stats-overlay">
                    <div>FPS: @_fps.ToString("F0")</div>
                    <div>Nodes: @_scene.GetAllNodes().Count()</div>
                    <div>Lights: @_scene.GetLightNodes().Count()</div>
                    <div>Selected: @_selectedIds.Count</div>
                    @if (_playMode)
                    {
                        <div>Pos: @_fpsCamera.Position.X.ToString("F1"), @_fpsCamera.Position.Y.ToString("F1"), @_fpsCamera.Position.Z.ToString("F1")</div>
                        <div>Grounded: @_fpsCamera.IsGrounded</div>
                    }
                </div>
            }
        </div>
    </div>

    @* --- Right: Inspector --- *@
    <div class="editor-inspector @(_playMode ? "panel-dimmed" : "")">
        <div class="sidebar-header">
            <strong>Inspector</strong>
        </div>
        @if (_selectedIds.Count > 1)
        {
            <div class="inspector-content">
                <div class="prop-group">
                    <label>Selection</label>
                    <span>@_selectedIds.Count objects selected</span>
                </div>
                <div class="prop-group mt-3">
                    <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">Delete All</button>
                    <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="DuplicateSelected">Duplicate All</button>
                </div>
                <div class="prop-group">
                    <label>Align</label>
                    <div style="display: flex; gap: 3px; flex-wrap: wrap;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AlignSelected(0, false)">Left</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AlignSelected(0, true)">Right</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AlignSelected(1, false)">Bottom</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AlignSelected(1, true)">Top</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AlignSelected(2, false)">Front</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AlignSelected(2, true)">Back</button>
                    </div>
                </div>
                <div class="prop-group">
                    <label>Distribute</label>
                    <div style="display: flex; gap: 3px;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => DistributeSelected(0)">X</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => DistributeSelected(1)">Y</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => DistributeSelected(2)">Z</button>
                    </div>
                </div>
            </div>
        }
        else if (_scene.SelectedNode is { } sel)
        {
            <div class="inspector-content">
                <div class="prop-group">
                    <label>Name</label>
                    <input type="text" class="form-control form-control-sm" @bind="sel.Name" @bind:event="oninput" />
                </div>

                <div class="prop-group">
                    <label>Visible</label>
                    <input type="checkbox" @bind="sel.Visible" />
                </div>

                <div class="prop-group">
                    <label>Solid</label>
                    <input type="checkbox" @bind="sel.Solid" />
                </div>

                <div class="prop-group">
                    <label>Locked</label>
                    <input type="checkbox" @bind="sel.Locked" />
                </div>

                <div class="prop-group">
                    <label>Tag</label>
                    <select class="form-control form-control-sm" @bind="sel.Tag">
                        @foreach (var t in Enum.GetValues<NodeTag>())
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>

                <div class="prop-group">
                    <label>Position</label>
                    <div class="vec3-row">
                        <div class="vec3-field"><span>X</span><input type="number" step="0.1" value="@sel.Transform.Position.X.ToString("F2")" @onchange="e => SetPosition(sel, 0, e)" /></div>
                        <div class="vec3-field"><span>Y</span><input type="number" step="0.1" value="@sel.Transform.Position.Y.ToString("F2")" @onchange="e => SetPosition(sel, 1, e)" /></div>
                        <div class="vec3-field"><span>Z</span><input type="number" step="0.1" value="@sel.Transform.Position.Z.ToString("F2")" @onchange="e => SetPosition(sel, 2, e)" /></div>
                    </div>
                </div>

                <div class="prop-group">
                    <label>Rotation (deg)</label>
                    @{ var euler = sel.Transform.EulerAngles * (180f / MathF.PI); }
                    <div class="vec3-row">
                        <div class="vec3-field"><span>X</span><input type="number" step="1" value="@euler.X.ToString("F1")" @onchange="e => SetRotation(sel, 0, e)" /></div>
                        <div class="vec3-field"><span>Y</span><input type="number" step="1" value="@euler.Y.ToString("F1")" @onchange="e => SetRotation(sel, 1, e)" /></div>
                        <div class="vec3-field"><span>Z</span><input type="number" step="1" value="@euler.Z.ToString("F1")" @onchange="e => SetRotation(sel, 2, e)" /></div>
                    </div>
                </div>

                <div class="prop-group">
                    <label>Scale</label>
                    <div class="vec3-row">
                        <div class="vec3-field"><span>X</span><input type="number" step="0.1" value="@sel.Transform.Scale.X.ToString("F2")" @onchange="e => SetScale(sel, 0, e)" /></div>
                        <div class="vec3-field"><span>Y</span><input type="number" step="0.1" value="@sel.Transform.Scale.Y.ToString("F2")" @onchange="e => SetScale(sel, 1, e)" /></div>
                        <div class="vec3-field"><span>Z</span><input type="number" step="0.1" value="@sel.Transform.Scale.Z.ToString("F2")" @onchange="e => SetScale(sel, 2, e)" /></div>
                    </div>
                </div>

                <div class="prop-group">
                    <label>Material</label>
                    <select class="form-control form-control-sm" value="@(sel.MaterialPreset ?? "")" @onchange="e => ApplyMaterial(sel, e)">
                        <option value="">Custom</option>
                        @foreach (var preset in MaterialPresets.All)
                        {
                            <option value="@preset.Name">@preset.Name</option>
                        }
                    </select>
                </div>

                <div class="prop-group">
                    <label>Color</label>
                    <input type="color"
                           value="@ColorToHex(sel.Color)"
                           @onchange="e => SetNodeColor(sel, e)" />
                </div>

                @if (sel.Light is { } light)
                {
                    <div class="prop-group">
                        <label>Light Color</label>
                        <input type="color"
                               value="@Vec3ToHex(light.Color)"
                               @onchange="e => SetLightColor(light, e)" />
                    </div>
                    <div class="prop-group">
                        <label>Intensity</label>
                        <input type="range" min="0.5" max="10" step="0.5"
                               value="@light.Intensity.ToString("F1")"
                               @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) light.Intensity = v; }" />
                        <span class="text-muted small">@light.Intensity.ToString("F1")</span>
                    </div>
                    <div class="prop-group">
                        <label>Range</label>
                        <input type="range" min="1" max="30" step="1"
                               value="@light.Range.ToString("F0")"
                               @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) light.Range = v; }" />
                        <span class="text-muted small">@light.Range.ToString("F0")</span>
                    </div>
                }

                <div class="prop-group">
                    <label>Script</label>
                    <select class="form-control form-control-sm" style="margin-bottom: 4px;"
                            @onchange="e => ApplyScriptTemplate(sel, e)">
                        <option value="">-- Insert template --</option>
                        @foreach (var t in ScriptTemplates)
                        {
                            <option value="@t.name">@t.name</option>
                        }
                    </select>
                    <textarea class="form-control form-control-sm script-editor"
                              rows="5" spellcheck="false"
                              placeholder="// Select a template above or write commands"
                              @bind="sel.Script" @bind:event="onchange"></textarea>
                </div>

                <div class="prop-group mt-3">
                    <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">Delete</button>
                    <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="DuplicateSelected">Duplicate</button>
                </div>
            </div>
        }
        else
        {
            <div class="inspector-content">
                <div class="prop-group">
                    <label class="section-label">Scene Settings</label>
                </div>

                <div class="prop-group">
                    <label>Sky Zenith</label>
                    <input type="color" value="@Vec3ToHex(_settings.SkyZenith)"
                           @onchange="e => _settings.SkyZenith = HexToVec3(e)" />
                </div>
                <div class="prop-group">
                    <label>Sky Horizon</label>
                    <input type="color" value="@Vec3ToHex(_settings.SkyHorizon)"
                           @onchange="e => _settings.SkyHorizon = HexToVec3(e)" />
                </div>
                <div class="prop-group">
                    <label>Sky Ground</label>
                    <input type="color" value="@Vec3ToHex(_settings.SkyGround)"
                           @onchange="e => _settings.SkyGround = HexToVec3(e)" />
                </div>

                <div class="prop-group">
                    <label>Sun Color</label>
                    <input type="color" value="@Vec3ToHex(_settings.SunColor)"
                           @onchange="e => _settings.SunColor = HexToVec3(e)" />
                </div>
                <div class="prop-group">
                    <label>Sun Intensity</label>
                    <input type="range" min="0" max="2" step="0.05"
                           value="@_settings.SunIntensity.ToString("F2")"
                           @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) _settings.SunIntensity = v; }" />
                    <span class="text-muted small">@_settings.SunIntensity.ToString("F2")</span>
                </div>

                <div class="prop-group">
                    <label>Ambient Color</label>
                    <input type="color" value="@Vec3ToHex(_settings.AmbientColor)"
                           @onchange="e => _settings.AmbientColor = HexToVec3(e)" />
                </div>

                <div class="prop-group">
                    <label>Fog Color</label>
                    <input type="color" value="@Vec3ToHex(_settings.FogColor)" @onchange="e => _settings.FogColor = HexToVec3(e)" />
                </div>
                <div class="prop-group">
                    <label>Fog Start</label>
                    <input type="range" min="5" max="100" step="5" value="@_settings.FogStart.ToString("F0")" @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) _settings.FogStart = v; }" />
                    <span class="text-muted small">@_settings.FogStart.ToString("F0")</span>
                </div>
                <div class="prop-group">
                    <label>Fog End</label>
                    <input type="range" min="10" max="200" step="5" value="@_settings.FogEnd.ToString("F0")" @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) _settings.FogEnd = v; }" />
                    <span class="text-muted small">@_settings.FogEnd.ToString("F0")</span>
                </div>

                <div class="prop-group" style="margin-top: 12px;">
                    <label class="section-label">Gameplay</label>
                </div>
                <div class="prop-group">
                    <label>Level Timer</label>
                    <input type="checkbox" @bind="_timerEnabled" /> Enable
                </div>
                @if (_timerEnabled)
                {
                    <div class="prop-group">
                        <label>Time Limit</label>
                        <input type="range" min="10" max="300" step="10" value="@_levelTimerMax.ToString("F0")" @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) _levelTimerMax = v; }" />
                        <span class="text-muted small">@_levelTimerMax.ToString("F0")s</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private string? _error;
    private float _fps;
    private GpuLoop? _loop;
    private GpuInput? _input;
    private GpuDevice? _device;
    private SceneRenderer? _renderer;
    private readonly Scene _scene = new();
    private readonly OrbitCamera _camera = new();
    private (float yaw, float pitch, float distance, Vector3 target)?[] _cameraBookmarks = new (float, float, float, Vector3)?[4];
    private readonly UndoStack _undo = new();
    private readonly SceneSettings _settings = new();
    private readonly FpsCamera _fpsCamera = new();
    private bool _playMode;

    // Play-mode game state
    private int _score;
    private int _totalCollectibles;
    private bool _hasEnemies;
    private float _playTime;
    private readonly HashSet<int> _collectedIds = new();

    // Trigger zone state
    private readonly HashSet<int> _activeTriggers = new();
    private string? _triggerMessage;
    private float _triggerMessageTimer;

    // Teleporter state
    private float _teleportCooldown;

    // Door-and-key state
    private readonly HashSet<string> _collectedKeys = new();

    // Enemy/health state
    private int _playerHealth = 100;
    private float _damageCooldown;
    private float _damageZoneCooldown;

    // Checkpoint state
    private Vector3 _lastCheckpoint = Vector3.Zero;

    // Timer
    private float _levelTimer;
    private float _levelTimerMax = 60f;
    private bool _timerEnabled;

    // Script engine state
    private Dictionary<int, (List<ScriptCommand> cmds, ScriptState state, Vector3 startPos)> _scriptData = new();

    // Hierarchy drag-drop
    private int? _dragNodeId;

    // Multi-selection
    private readonly HashSet<int> _selectedIds = new();

    // Copy-paste clipboard
    private List<(string name, string? meshType, string? materialPreset, NodeTag tag, bool solid, bool visible, Vector4 color, Vector3 pos, Quaternion rot, Vector3 scale, PointLightData? light, byte[]? importedData, string? importedFileName)> _clipboard = new();

    // Grid snap
    private bool _snapEnabled = true;
    private bool _showStats;
    private float _snapSize = 0.5f;
    private static readonly float[] SnapPresets = [0.1f, 0.25f, 0.5f, 1f, 2f];

    // Cached primitive meshes
    private MeshBuffers? _cubeMesh;
    private MeshBuffers? _sphereMesh;
    private MeshBuffers? _sphereLod1;
    private MeshBuffers? _sphereLod2;
    private MeshBuffers? _planeMesh;
    private MeshBuffers? _cylinderMesh;
    private MeshBuffers? _cylinderLod1;
    private MeshBuffers? _cylinderLod2;
    private int _nodeCounter;

    private enum PrimitiveType { Cube, Sphere, Plane, Cylinder }
    private MeshBuffers? _lightMesh; // small sphere for light icons

    private static readonly Vector4[] PaletteColors =
    [
        new(0.85f, 0.85f, 0.85f, 1), // light grey
        new(0.92f, 0.35f, 0.30f, 1), // red
        new(0.30f, 0.69f, 0.31f, 1), // green
        new(0.26f, 0.52f, 0.96f, 1), // blue
        new(1.00f, 0.76f, 0.03f, 1), // yellow
        new(0.61f, 0.35f, 0.71f, 1), // purple
        new(0.00f, 0.74f, 0.83f, 1), // cyan
        new(1.00f, 0.60f, 0.00f, 1), // orange
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var adapter = await Gpu.RequestAdapterAsync(JS);
            _device = await adapter.RequestDeviceAsync();
            var canvas = await GpuCanvas.ConfigureAsync(_device, "gpu-canvas");
            _input = await GpuInput.InitAsync(_device, "gpu-canvas");

            // Create renderer
            _renderer = await SceneRenderer.CreateAsync(_device, canvas.Format);

            // Create cached primitive meshes + LOD variants
            _cubeMesh = await Primitives.Cube().CreateBuffersAsync(_device);
            _sphereMesh = await Primitives.Sphere().CreateBuffersAsync(_device);
            _sphereLod1 = await Primitives.Sphere(10, 20).CreateBuffersAsync(_device);
            _sphereLod2 = await Primitives.Sphere(6, 12).CreateBuffersAsync(_device);
            _planeMesh = await Primitives.Plane(4).CreateBuffersAsync(_device);
            _cylinderMesh = await Primitives.Cylinder().CreateBuffersAsync(_device);
            _cylinderLod1 = await Primitives.Cylinder(16).CreateBuffersAsync(_device);
            _cylinderLod2 = await Primitives.Cylinder(8).CreateBuffersAsync(_device);
            _lightMesh = await Primitives.Sphere(8, 16).CreateBuffersAsync(_device);

            // Setup default scene
            await SetupDefaultScene();

            // Depth buffer
            var depthTexture = await canvas.CreateDepthTextureAsync(_device);
            var depthView = await depthTexture.CreateViewAsync();

            _loop = await Gpu.RunLoopAsync(_device, async (frame) =>
            {
                _fps = frame.Fps;

                // Handle canvas resize
                if (await canvas.ResizeToDisplaySizeAsync())
                {
                    await depthTexture.DisposeAsync();
                    depthTexture = await canvas.CreateDepthTextureAsync(_device);
                    depthView = await depthTexture.CreateViewAsync();
                }

                var input = await _input!.GetStateAsync();

                if (_playMode)
                {
                    // --- Play mode: FPS camera + gameplay ---
                    _scene.UpdateTransforms(); // Once per frame, before all gameplay
                    _fpsCamera.ProcessInput(input, frame.DeltaTime, _scene);
                    _playTime += frame.DeltaTime;

                    // Escape exits play mode
                    if (input.WasKeyPressed("Escape"))
                    {
                        ExitPlayMode();
                        _scene.UpdateTransforms();
                        // Skip to editor render below
                    }

                    if (_playMode)
                    {
                    // Gameplay
                    UpdateCollectibles(frame.DeltaTime);
                    CheckTriggers(frame.DeltaTime);
                    UpdateEnemies(frame.DeltaTime);
                    UpdateDoorsAndKeys(frame.DeltaTime);
                    UpdateTeleporters();
                    UpdateDamageZones(frame.DeltaTime);
                    UpdateHealthPickups();
                    UpdateMovingPlatforms(frame.DeltaTime);
                    CheckCheckpoints();
                    UpdateNPCs();
                    ExecuteScripts(frame.DeltaTime);

                    // Timer countdown
                    if (_timerEnabled)
                    {
                        _levelTimer -= frame.DeltaTime;
                        if (_levelTimer <= 0) { _levelTimer = 0; _playerHealth = 0; }
                    }

                    // Respawn to checkpoint on death (after 2 seconds)
                    if (_playerHealth <= 0 && _damageCooldown <= 0)
                    {
                        _playerHealth = 50;
                        _fpsCamera.Position = _lastCheckpoint + new Vector3(0, FpsCamera.EyeHeight, 0);
                        _damageCooldown = 2f;
                    }

                    _scene.UpdateTransforms();

                    var batch = new RenderBatch(_device);
                    var colorView = batch.GetCurrentTextureView(canvas);
                    _renderer!.Render(batch, _scene, _fpsCamera, canvas, colorView, depthView, _settings);
                    await batch.FlushAsync();

                    // Minimap
                    await DrawMinimap();
                    } // end if (_playMode) gameplay+render
                }
                else
                {
                    // --- Editor mode: orbit camera + gizmo + picking ---
                    var gizmo = _renderer!.Gizmo!;
                    bool gizmoActive = ProcessGizmo(input, canvas, gizmo);

                    if (!gizmoActive)
                    {
                        _camera.ProcessInput(input, frame.DeltaTime);
                        ProcessPicking(input, canvas);
                        ProcessBoxSelect(input, canvas);
                    }

                    ProcessShortcuts(input);

                    _scene.UpdateTransforms();

                    var batch = new RenderBatch(_device);
                    var colorView = batch.GetCurrentTextureView(canvas);
                    _renderer!.Render(batch, _scene, _camera, canvas, colorView, depthView, _settings, _selectedIds);
                    await batch.FlushAsync();
                }

                if (frame.FrameIndex % 20 == 0) StateHasChanged();
            });

            StateHasChanged();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            StateHasChanged();
        }
    }

    private void AddLight()
    {
        var node = new SceneNode($"Light {++_nodeCounter}")
        {
            MeshBuffers = _lightMesh,
            MeshType = "Light",
            Color = new Vector4(1f, 0.95f, 0.6f, 1f), // warm yellow icon
            Light = new PointLightData
            {
                Color = new Vector3(1f, 0.95f, 0.8f),
                Intensity = 3f,
                Range = 10f,
            },
        };
        node.Transform.Position = SnapPosition(new Vector3(0, 2f, 0));
        node.Transform.Scale = new Vector3(0.2f); // small icon sphere
        _undo.Do(new AddNodeAction(_scene, node));
        SelectSingle(node);
    }

    // --- Selection helpers ---

    private bool IsSelected(int nodeId) => _selectedIds.Contains(nodeId);

    private void SelectSingle(SceneNode? node)
    {
        _selectedIds.Clear();
        if (node is not null) _selectedIds.Add(node.Id);
        _scene.SelectedNode = node;
    }

    private void ToggleSelect(SceneNode node)
    {
        if (_selectedIds.Contains(node.Id))
        {
            _selectedIds.Remove(node.Id);
            _scene.SelectedNode = _selectedIds.Count > 0 ? _scene.FindById(_selectedIds.First()) : null;
        }
        else
        {
            _selectedIds.Add(node.Id);
            _scene.SelectedNode = node;
        }
    }

    private void SelectAll()
    {
        _selectedIds.Clear();
        SceneNode? last = null;
        foreach (var node in _scene.GetAllNodes())
        {
            _selectedIds.Add(node.Id);
            last = node;
        }
        _scene.SelectedNode = last;
    }

    private void ClearSelection()
    {
        _selectedIds.Clear();
        _scene.SelectedNode = null;
    }

    private List<SceneNode> GetSelectedNodes()
    {
        var nodes = new List<SceneNode>();
        foreach (var id in _selectedIds)
        {
            var node = _scene.FindById(id);
            if (node is not null) nodes.Add(node);
        }
        return nodes;
    }

    private void ReparentNode(SceneNode newParent)
    {
        if (_dragNodeId is null) return;
        var dragNode = _scene.FindById(_dragNodeId.Value);
        if (dragNode is null || dragNode == newParent) return;
        if (newParent.FindById(dragNode.Id) is not null) return;
        dragNode.Detach();
        _scene.Remove(dragNode);
        newParent.AddChild(dragNode);
        _dragNodeId = null;
    }

    private void ReparentToRoot()
    {
        if (_dragNodeId is null) return;
        var dragNode = _scene.FindById(_dragNodeId.Value);
        if (dragNode is null) return;
        dragNode.Detach();
        _scene.Remove(dragNode);
        _scene.Add(dragNode);
        _dragNodeId = null;
    }

