    // --- Prefab system ---

    private void AddPrefab(string prefabType)
    {
        var spawnPos = _camera.Target;

        switch (prefabType)
        {
            case "playerstart":
            {
                var node = AddCylinder("Player Start", spawnPos + new Vector3(0, 0.15f, 0), new Vector3(1, 0.3f, 1), new Vector4(0.2f, 0.9f, 0.3f, 0.6f));
                node.Tag = NodeTag.Checkpoint;
                node.Solid = false;
                SelectSingle(node);
                break;
            }
            case "cointrail":
            {
                SceneNode? last = null;
                for (int i = 0; i < 5; i++)
                {
                    var cNode = new SceneNode($"Coin {i + 1}") { MeshBuffers = _sphereMesh, MeshType = "Sphere", Tag = NodeTag.Collectible, Color = PaletteColors[4] };
                    cNode.Transform.Position = spawnPos + new Vector3(i * 2, 0.5f, 0);
                    cNode.Transform.Scale = new Vector3(0.4f);
                    cNode.Script = "Rotate(0, 180, 0)\nBob(3, 0.3)";
                    _scene.Add(cNode);
                    _nodeCounter++;
                    last = cNode;
                }
                if (last is not null) SelectSingle(last);
                break;
            }
            case "movingplatform":
            {
                var node = AddBox("Moving Platform", spawnPos, new Vector3(4, 0.4f, 2), new Vector4(0.3f, 0.55f, 0.7f, 1));
                node.Tag = NodeTag.MovingPlatform;
                node.MoveTarget = spawnPos + new Vector3(0, 4, 0);
                SelectSingle(node);
                break;
            }
            case "turret":
            {
                var tBase = AddBox("Turret Base", spawnPos + new Vector3(0, 0.5f, 0), new Vector3(1.2f, 1, 1.2f), new Vector4(0.5f, 0.5f, 0.5f, 1));
                var barrel = AddCylinder("Turret Barrel", spawnPos + new Vector3(0, 1.2f, 0.6f), new Vector3(0.25f, 0.25f, 1f), new Vector4(0.6f, 0.6f, 0.6f, 1));
                barrel.Script = "LookAtPlayer()";
                tBase.AddChild(barrel);
                SelectSingle(tBase);
                break;
            }
            case "gatekey":
            {
                var door = new SceneNode("Gate Door") { MeshBuffers = _cubeMesh, MeshType = "Cube", Tag = NodeTag.Door, Color = new Vector4(0.8f, 0.5f, 0.15f, 0.85f) };
                door.Transform.Position = spawnPos + new Vector3(0, 1.5f, 0);
                door.Transform.Scale = new Vector3(3, 3, 0.5f);
                _scene.Add(door); _nodeCounter++;

                var key = new SceneNode("Gate Key") { MeshBuffers = _sphereMesh, MeshType = "Sphere", Tag = NodeTag.Key, Color = new Vector4(0.8f, 0.5f, 0.15f, 1) };
                key.Transform.Position = spawnPos + new Vector3(5, 0.5f, 0);
                key.Transform.Scale = new Vector3(0.35f);
                key.Script = "Rotate(0, 120, 0)\nBob(2, 0.2)";
                _scene.Add(key); _nodeCounter++;

                SelectSingle(door);
                break;
            }
            case "enemypatrol":
            {
                var enemy = new SceneNode("Patrol Enemy") { MeshBuffers = _sphereMesh, MeshType = "Sphere", Tag = NodeTag.Enemy, Color = new Vector4(0.9f, 0.15f, 0.1f, 1) };
                enemy.Transform.Position = spawnPos + new Vector3(0, 0.5f, 0);
                enemy.Script = "FollowPlayer(3, 12)\nLookAtPlayer()";
                _scene.Add(enemy); _nodeCounter++;
                SelectSingle(enemy);
                break;
            }
            case "lightpost":
            {
                var post = AddCylinder("Light Post", spawnPos + new Vector3(0, 1.5f, 0), new Vector3(0.15f, 3, 0.15f), new Vector4(0.45f, 0.45f, 0.45f, 1));
                AddLightNode(spawnPos + new Vector3(0, 3.5f, 0), new Vector3(1f, 0.9f, 0.7f), 3f, 12f);
                SelectSingle(post);
                break;
            }
        }
    }

    private void AddPrimitive(PrimitiveType type)
    {
        var name = $"{type} {++_nodeCounter}";
        var node = new SceneNode(name)
        {
            MeshBuffers = ResolveMesh(type.ToString()),
            MeshType = type.ToString(),
            Color = PaletteColors[_nodeCounter % PaletteColors.Length],
            LodMeshes = ResolveLodMeshes(type.ToString()),
        };
        node.Transform.Position = SnapPosition(new Vector3(0, 0.5f, 0));
        _undo.Do(new AddNodeAction(_scene, node));
        SelectSingle(node);
    }

    private MeshBuffers?[]? ResolveLodMeshes(string? meshType) => meshType switch
    {
        "Sphere" => [_sphereLod1, _sphereLod2],
        "Cylinder" => [_cylinderLod1, _cylinderLod2],
        _ => null,
    };

    private MeshBuffers? ResolveMesh(string? meshType) => meshType switch
    {
        "Cube" => _cubeMesh,
        "Sphere" => _sphereMesh,
        "Plane" => _planeMesh,
        "Cylinder" => _cylinderMesh,
        "Light" => _lightMesh,
        _ => null,
    };

    private MeshBuffers? ResolveMeshFull(string meshType, byte[]? importedData, string? importedFileName)
    {
        if (meshType == "Imported" && importedData is not null && importedFileName is not null)
            return CreateImportedMeshBuffers(importedData, importedFileName).GetAwaiter().GetResult();
        // ImportedSkinned nodes are set up via SetupSkinnedNodeFromGlb after rebuild — return null here
        if (meshType == "ImportedSkinned")
            return null;
        return ResolveMesh(meshType);
    }

    // --- Keyboard shortcuts ---

    private const float NudgeAmount = 0.25f;

    private void ProcessShortcuts(InputState input)
    {
        foreach (var key in input.KeyDownEvents)
        {
            switch (key)
            {
                // Delete selected nodes
                case "Delete" or "Backspace":
                    DeleteSelected();
                    break;

                // Ctrl+D — duplicate selected
                case "KeyD" when input.CtrlKey:
                    DuplicateSelected();
                    break;

                // Ctrl+A — select all
                case "KeyA" when input.CtrlKey:
                    SelectAll();
                    break;

                // F — focus camera on selected node
                case "KeyF":
                    if (_scene.SelectedNode is { } toFocus)
                    {
                        _scene.UpdateTransforms();
                        _camera.FocusOn(toFocus.Transform.WorldMatrix.Translation);
                    }
                    else
                    {
                        _camera.FocusOn(Vector3.Zero);
                    }
                    break;

                // Ctrl+Z — undo
                case "KeyZ" when input.CtrlKey && !input.ShiftKey:
                    _undo.Undo();
                    break;

                // Ctrl+Y or Ctrl+Shift+Z — redo
                case "KeyY" when input.CtrlKey:
                case "KeyZ" when input.CtrlKey && input.ShiftKey:
                    _undo.Redo();
                    break;

                // W/E/R — switch gizmo mode
                case "KeyW" when !input.CtrlKey:
                    _renderer!.Gizmo!.Mode = GizmoMode.Translate;
                    break;
                case "KeyE" when !input.CtrlKey:
                    _renderer!.Gizmo!.Mode = GizmoMode.Rotate;
                    break;
                case "KeyR" when !input.CtrlKey:
                    _renderer!.Gizmo!.Mode = GizmoMode.Scale;
                    break;

                // G — toggle grid snap
                case "KeyG" when !input.CtrlKey:
                    _snapEnabled = !_snapEnabled;
                    break;

                // L — toggle local/world space
                case "KeyL" when !input.CtrlKey:
                    _localSpace = !_localSpace;
                    break;

                // ? — show keyboard shortcuts
                case "Slash" when input.ShiftKey:
                    _showShortcuts = !_showShortcuts;
                    break;

                // Ctrl+1-4 — save camera bookmark; 1-4 — recall
                case "Digit1" when input.CtrlKey: _cameraBookmarks[0] = (_camera.Yaw, _camera.Pitch, _camera.Distance, _camera.Target); break;
                case "Digit2" when input.CtrlKey: _cameraBookmarks[1] = (_camera.Yaw, _camera.Pitch, _camera.Distance, _camera.Target); break;
                case "Digit3" when input.CtrlKey: _cameraBookmarks[2] = (_camera.Yaw, _camera.Pitch, _camera.Distance, _camera.Target); break;
                case "Digit4" when input.CtrlKey: _cameraBookmarks[3] = (_camera.Yaw, _camera.Pitch, _camera.Distance, _camera.Target); break;

                case "Digit1" when !input.CtrlKey && _cameraBookmarks[0].HasValue:
                    var b0 = _cameraBookmarks[0]!.Value; _camera.Yaw = b0.yaw; _camera.Pitch = b0.pitch; _camera.Distance = b0.distance; _camera.Target = b0.target; break;
                case "Digit2" when !input.CtrlKey && _cameraBookmarks[1].HasValue:
                    var b1 = _cameraBookmarks[1]!.Value; _camera.Yaw = b1.yaw; _camera.Pitch = b1.pitch; _camera.Distance = b1.distance; _camera.Target = b1.target; break;
                case "Digit3" when !input.CtrlKey && _cameraBookmarks[2].HasValue:
                    var b2 = _cameraBookmarks[2]!.Value; _camera.Yaw = b2.yaw; _camera.Pitch = b2.pitch; _camera.Distance = b2.distance; _camera.Target = b2.target; break;
                case "Digit4" when !input.CtrlKey && _cameraBookmarks[3].HasValue:
                    var b3 = _cameraBookmarks[3]!.Value; _camera.Yaw = b3.yaw; _camera.Pitch = b3.pitch; _camera.Distance = b3.distance; _camera.Target = b3.target; break;

                // Ctrl+C — copy selected
                case "KeyC" when input.CtrlKey:
                    _clipboard.Clear();
                    foreach (var node in GetSelectedNodes())
                        _clipboard.Add((node.Name, node.MeshType, node.MaterialPreset, node.Tag, node.Solid, node.Visible, node.Color, node.Transform.Position, node.Transform.Rotation, node.Transform.Scale, node.Light is { } l ? new PointLightData { Color = l.Color, Intensity = l.Intensity, Range = l.Range } : null, node.ImportedMeshData, node.ImportedMeshFileName));
                    break;

                // Ctrl+V — paste copied
                case "KeyV" when input.CtrlKey && _clipboard.Count > 0:
                    _selectedIds.Clear();
                    SceneNode? lastPasted = null;
                    foreach (var c in _clipboard)
                    {
                        var node = new SceneNode(c.name + " (paste)") { MeshBuffers = ResolveMesh(c.meshType), MeshType = c.meshType, MaterialPreset = c.materialPreset, Tag = c.tag, Solid = c.solid, Visible = c.visible, Color = c.color, Light = c.light, ImportedMeshData = c.importedData, ImportedMeshFileName = c.importedFileName };
                        node.Transform.Position = c.pos + new Vector3(1, 0, 1);
                        node.Transform.Rotation = c.rot;
                        node.Transform.Scale = c.scale;
                        if (c.meshType == "Imported" && c.importedData != null && c.importedFileName != null)
                            node.MeshBuffers = ResolveMeshFull("Imported", c.importedData, c.importedFileName);
                        _undo.Do(new AddNodeAction(_scene, node));
                        _selectedIds.Add(node.Id);
                        lastPasted = node;
                    }
                    _scene.SelectedNode = lastPasted;
                    break;

                case "F3":
                    _showStats = !_showStats;
                    break;

                // Escape — deselect
                case "Escape":
                    ClearSelection();
                    break;

                // Arrow keys — nudge selected node position
                case "ArrowRight" when _selectedIds.Count > 0:
                    NudgeSelected(input.ShiftKey ? Vector3.UnitZ : Vector3.UnitX);
                    break;
                case "ArrowLeft" when _selectedIds.Count > 0:
                    NudgeSelected(input.ShiftKey ? -Vector3.UnitZ : -Vector3.UnitX);
                    break;
                case "ArrowUp" when _selectedIds.Count > 0:
                    NudgeSelected(input.ShiftKey ? Vector3.UnitY : -Vector3.UnitZ);
                    break;
                case "ArrowDown" when _selectedIds.Count > 0:
                    NudgeSelected(input.ShiftKey ? -Vector3.UnitY : Vector3.UnitZ);
                    break;
            }
        }
    }

    private void NudgeSelected(Vector3 direction)
    {
        float step = _snapEnabled ? _snapSize : NudgeAmount;
        var delta = direction * step;
        foreach (var node in GetSelectedNodes())
        {
            if (node.Locked) continue;
            var oldPos = node.Transform.Position;
            var newPos = oldPos + delta;
            if (_snapEnabled) newPos = SnapPosition(newPos);
            _undo.Do(TransformAction.Move(node, oldPos, newPos));
        }
    }

    // --- Gizmo interaction ---

    private bool _gizmoDragging;
    private Vector3 _gizmoDragStartPos;
    private Quaternion _gizmoDragStartRot;
    private Vector3 _gizmoDragStartScale;
    // For multi-select group move: start positions of all selected nodes
    private Dictionary<int, (Vector3 pos, Quaternion rot, Vector3 scale)> _groupDragStarts = new();

    private bool ProcessGizmo(InputState input, GpuCanvas canvas, TranslateGizmo gizmo)
    {
        if (_selectedIds.Count == 0 || _scene.SelectedNode is not { } selected)
        {
            gizmo.HoveredAxis = GizmoAxis.None;
            return false;
        }

        if (selected.Locked) { gizmo.HoveredAxis = GizmoAxis.None; return false; }

        _scene.UpdateTransforms();
        var gizmoPos = selected.Transform.WorldMatrix.Translation;
        float camDist = Vector3.Distance(_camera.Position, gizmoPos);

        // Handle ongoing drag
        if (_gizmoDragging)
        {
            if (!input.LeftMouseDown)
            {
                // Mouse released — end drag, record undo action
                gizmo.EndDrag();
                _gizmoDragging = false;
                _ = JS.InvokeVoidAsync("WgpuSharp.setPointerLockBlocked", false);

                // Record undo for all nodes that moved
                foreach (var (id, start) in _groupDragStarts)
                {
                    var node = _scene.FindById(id);
                    if (node is null) continue;
                    var t = node.Transform;
                    if (t.Position != start.pos || t.Rotation != start.rot || t.Scale != start.scale)
                    {
                        _undo.Push(new TransformAction(node,
                            start.pos, start.rot, start.scale,
                            t.Position, t.Rotation, t.Scale));
                    }
                }
                return false;
            }

            // Update drag using current mouse
            var ray = Picking.ScreenPointToRay(
                input.MouseX, input.MouseY,
                canvas.Width, canvas.Height,
                _camera.ViewMatrix, _camera.ProjectionMatrix(canvas.AspectRatio));

            switch (gizmo.Mode)
            {
                case GizmoMode.Translate:
                    var newPos = SnapPosition(gizmo.UpdateTranslateDrag(ray));
                    var moveDelta = newPos - _gizmoDragStartPos;
                    foreach (var (id, start) in _groupDragStarts)
                    {
                        var n = _scene.FindById(id);
                        if (n is not null) n.Transform.Position = SnapPosition(start.pos + moveDelta);
                    }
                    break;
                case GizmoMode.Rotate:
                    var newRot = gizmo.UpdateRotateDrag(ray);
                    if (_snapEnabled)
                    {
                        // Snap to 15-degree increments
                        var euler = selected.Transform.EulerAngles;
                        // Get the euler from the new rotation
                        var tempTransform = new Transform();
                        tempTransform.Rotation = newRot;
                        var newEuler = tempTransform.EulerAngles;
                        float snapRad = 15f * MathF.PI / 180f;
                        newEuler = new Vector3(
                            MathF.Round(newEuler.X / snapRad) * snapRad,
                            MathF.Round(newEuler.Y / snapRad) * snapRad,
                            MathF.Round(newEuler.Z / snapRad) * snapRad);
                        tempTransform.EulerAngles = newEuler;
                        selected.Transform.Rotation = tempTransform.Rotation;
                    }
                    else
                    {
                        selected.Transform.Rotation = newRot;
                    }
                    break;
                case GizmoMode.Scale:
                    selected.Transform.Scale = gizmo.UpdateScaleDrag(ray);
                    break;
            }
            return true; // consume input — block camera
        }

        // Check for mousedown on gizmo axis to start drag
        foreach (var md in input.MouseDownEvents)
        {
            if (md.Button != 0) continue;

            var ray = Picking.ScreenPointToRay(
                md.X, md.Y,
                canvas.Width, canvas.Height,
                _camera.ViewMatrix, _camera.ProjectionMatrix(canvas.AspectRatio));

            var hitAxis = gizmo.HitTest(ray, gizmoPos, camDist);
            if (hitAxis != GizmoAxis.None)
            {
                _gizmoDragStartPos = selected.Transform.Position;
                _gizmoDragStartRot = selected.Transform.Rotation;
                _gizmoDragStartScale = selected.Transform.Scale;
                // Capture start transforms for all selected
                _groupDragStarts.Clear();
                foreach (var node in GetSelectedNodes())
                    _groupDragStarts[node.Id] = (node.Transform.Position, node.Transform.Rotation, node.Transform.Scale);
                gizmo.BeginDrag(hitAxis, selected.Transform.Position,
                    selected.Transform.Rotation, selected.Transform.Scale, ray);
                _gizmoDragging = true;
                _ = JS.InvokeVoidAsync("WgpuSharp.setPointerLockBlocked", true);
                return true;
            }
        }

        // Update hover highlighting from mouse position
        if (!input.PointerLocked)
        {
            var ray = Picking.ScreenPointToRay(
                input.MouseX, input.MouseY,
                canvas.Width, canvas.Height,
                _camera.ViewMatrix, _camera.ProjectionMatrix(canvas.AspectRatio));
            gizmo.HoveredAxis = gizmo.HitTest(ray, gizmoPos, camDist);
        }

        return false;
    }

    // --- Viewport picking ---

    private void ProcessPicking(InputState input, GpuCanvas canvas)
    {
        foreach (var click in input.ClickEvents)
        {
            if (click.Button != 0) continue; // left click only

            _scene.UpdateTransforms();

            var ray = Picking.ScreenPointToRay(
                click.X, click.Y,
                canvas.Width, canvas.Height,
                _camera.ViewMatrix,
                _camera.ProjectionMatrix(canvas.AspectRatio));

            var hit = Picking.PickNode(ray, _scene);
            if (input.ShiftKey && hit is not null)
                ToggleSelect(hit.Value.node);
            else
                SelectSingle(hit?.node);
        }
    }

    private void ProcessBoxSelect(InputState input, GpuCanvas canvas)
    {
        foreach (var box in input.BoxSelectEvents)
        {
            _scene.UpdateTransforms();
            var vp = _camera.ViewProjectionMatrix(canvas.AspectRatio);
            var hits = Picking.BoxSelect(_scene, box.X1, box.Y1, box.X2, box.Y2,
                canvas.Width, canvas.Height, vp);
            _selectedIds.Clear();
            SceneNode? last = null;
            foreach (var node in hits)
            {
                _selectedIds.Add(node.Id);
                last = node;
            }
            _scene.SelectedNode = last;
        }
    }

    private void DeleteSelected()
    {
        foreach (var node in GetSelectedNodes().Where(n => !n.Locked))
            _undo.Do(new DeleteNodeAction(_scene, node));
        ClearSelection();
    }

    private void DuplicateSelected()
    {
        var originals = GetSelectedNodes();
        if (originals.Count == 0) return;

        _selectedIds.Clear();
        SceneNode? last = null;
        foreach (var original in originals)
        {
            var dupe = new SceneNode($"{original.Name} (copy)")
            {
                MeshBuffers = original.MeshBuffers,
                MeshType = original.MeshType,
                Tag = original.Tag,
                ImportedMeshData = original.ImportedMeshData,
                ImportedMeshFileName = original.ImportedMeshFileName,
                Color = original.Color,
                MaterialPreset = original.MaterialPreset,
                Visible = original.Visible,
                Solid = original.Solid,
                Locked = false,
                MoveTarget = original.MoveTarget,
                Script = original.Script,
                LodMeshes = original.LodMeshes,
                Light = original.Light is { } l ? new PointLightData
                {
                    Color = l.Color,
                    Intensity = l.Intensity,
                    Range = l.Range,
                } : null,
            };
            dupe.Transform.Position = original.Transform.Position + new Vector3(1, 0, 0);
            dupe.Transform.Rotation = original.Transform.Rotation;
            dupe.Transform.Scale = original.Transform.Scale;

            _undo.Do(new AddNodeAction(_scene, dupe, original.Parent));
            _selectedIds.Add(dupe.Id);
            last = dupe;
        }
        _scene.SelectedNode = last;
    }

    private void AlignSelected(int axis, bool max)
    {
        var nodes = GetSelectedNodes();
        if (nodes.Count < 2) return;
        float target = max
            ? nodes.Max(n => GetAxis(n.Transform.Position, axis))
            : nodes.Min(n => GetAxis(n.Transform.Position, axis));
        foreach (var node in nodes)
        {
            var oldPos = node.Transform.Position;
            var newPos = SetAxis(oldPos, axis, target);
            _undo.Do(TransformAction.Move(node, oldPos, newPos));
        }
    }

    private void DistributeSelected(int axis)
    {
        var nodes = GetSelectedNodes().OrderBy(n => GetAxis(n.Transform.Position, axis)).ToList();
        if (nodes.Count < 3) return;
        float min = GetAxis(nodes[0].Transform.Position, axis);
        float max = GetAxis(nodes[^1].Transform.Position, axis);
        float step = (max - min) / (nodes.Count - 1);
        for (int i = 1; i < nodes.Count - 1; i++)
        {
            var oldPos = nodes[i].Transform.Position;
            var newPos = SetAxis(oldPos, axis, min + step * i);
            _undo.Do(TransformAction.Move(nodes[i], oldPos, newPos));
        }
    }

    private static float GetAxis(Vector3 v, int axis) => axis switch { 0 => v.X, 1 => v.Y, _ => v.Z };
    private static Vector3 SetAxis(Vector3 v, int axis, float val) => axis switch
    {
        0 => v with { X = val },
        1 => v with { Y = val },
        _ => v with { Z = val },
    };

    // --- Property setters ---

    private void SetPosition(SceneNode node, int axis, ChangeEventArgs e)
    {
        if (!float.TryParse(e.Value?.ToString(), out float val)) return;
        val = SnapValue(val);
        var oldPos = node.Transform.Position;
        var newPos = axis switch
        {
            0 => oldPos with { X = val },
            1 => oldPos with { Y = val },
            2 => oldPos with { Z = val },
            _ => oldPos,
        };
        _undo.Do(TransformAction.Move(node, oldPos, newPos));
    }

    private void SetRotation(SceneNode node, int axis, ChangeEventArgs e)
    {
        if (!float.TryParse(e.Value?.ToString(), out float deg)) return;
        if (_snapEnabled) deg = MathF.Round(deg / 15f) * 15f;
        var oldRot = node.Transform.Rotation;
        var oldPos = node.Transform.Position;
        var oldScale = node.Transform.Scale;
        var euler = node.Transform.EulerAngles * (180f / MathF.PI);
        euler = axis switch
        {
            0 => euler with { X = deg },
            1 => euler with { Y = deg },
            2 => euler with { Z = deg },
            _ => euler,
        };
        var newRot = Quaternion.CreateFromYawPitchRoll(
            euler.Y * (MathF.PI / 180f), euler.X * (MathF.PI / 180f), euler.Z * (MathF.PI / 180f));
        _undo.Do(new TransformAction(node, oldPos, oldRot, oldScale, oldPos, newRot, oldScale));
    }

    private void SetScale(SceneNode node, int axis, ChangeEventArgs e)
    {
        if (!float.TryParse(e.Value?.ToString(), out float val)) return;
        var oldScale = node.Transform.Scale;
        var oldPos = node.Transform.Position;
        var oldRot = node.Transform.Rotation;
        var newScale = axis switch
        {
            0 => oldScale with { X = val },
            1 => oldScale with { Y = val },
            2 => oldScale with { Z = val },
            _ => oldScale,
        };
        _undo.Do(new TransformAction(node, oldPos, oldRot, oldScale, oldPos, oldRot, newScale));
    }

    private void ApplyMaterial(SceneNode node, ChangeEventArgs e)
    {
        var name = e.Value?.ToString();
        if (string.IsNullOrEmpty(name))
        {
            node.MaterialPreset = null;
            return;
        }
        var preset = MaterialPresets.Find(name);
        if (preset is null) return;
        node.MaterialPreset = name;
        node.Color = preset.Color;
    }

    private void SetNodeColor(SceneNode node, ChangeEventArgs e)
    {
        var hex = e.Value?.ToString() ?? "#ffffff";
        var oldColor = node.Color;
        var newColor = HexToColor(hex);
        _undo.Do(new ColorAction(node, oldColor, newColor));
    }

    private static string ColorToHex(Vector4 c) =>
        $"#{(int)(c.X * 255):X2}{(int)(c.Y * 255):X2}{(int)(c.Z * 255):X2}";

    private static Vector4 HexToColor(string hex)
    {
        if (hex.StartsWith('#')) hex = hex[1..];
        if (hex.Length < 6) return Vector4.One;
        float r = int.Parse(hex[0..2], System.Globalization.NumberStyles.HexNumber) / 255f;
        float g = int.Parse(hex[2..4], System.Globalization.NumberStyles.HexNumber) / 255f;
        float b = int.Parse(hex[4..6], System.Globalization.NumberStyles.HexNumber) / 255f;
        return new Vector4(r, g, b, 1);
    }

    private static string Vec3ToHex(Vector3 c) =>
        $"#{(int)(c.X * 255):X2}{(int)(c.Y * 255):X2}{(int)(c.Z * 255):X2}";

    private static Vector3 HexToVec3(ChangeEventArgs e)
    {
        var hex = e.Value?.ToString() ?? "#ffffff";
        if (hex.StartsWith('#')) hex = hex[1..];
        if (hex.Length < 6) return Vector3.One;
        return new Vector3(
            int.Parse(hex[0..2], System.Globalization.NumberStyles.HexNumber) / 255f,
            int.Parse(hex[2..4], System.Globalization.NumberStyles.HexNumber) / 255f,
            int.Parse(hex[4..6], System.Globalization.NumberStyles.HexNumber) / 255f);
    }

    private void SetLightColor(PointLightData light, ChangeEventArgs e)
    {
        var hex = e.Value?.ToString() ?? "#ffffff";
        if (hex.StartsWith('#')) hex = hex[1..];
        if (hex.Length < 6) return;
        light.Color = new Vector3(
            int.Parse(hex[0..2], System.Globalization.NumberStyles.HexNumber) / 255f,
            int.Parse(hex[2..4], System.Globalization.NumberStyles.HexNumber) / 255f,
            int.Parse(hex[4..6], System.Globalization.NumberStyles.HexNumber) / 255f);
    }

    // --- Hierarchy rendering ---

    private IEnumerable<(SceneNode node, int depth)> GetFlatHierarchy()
    {
        bool hasFilter = !string.IsNullOrWhiteSpace(_hierarchyFilter);
        foreach (var root in _scene.Roots)
        {
            foreach (var item in FlattenNode(root, 0, hasFilter))
                yield return item;
        }
    }

    private IEnumerable<(SceneNode node, int depth)> FlattenNode(SceneNode node, int depth, bool hasFilter)
    {
        bool matchesFilter = !hasFilter || node.Name.Contains(_hierarchyFilter, StringComparison.OrdinalIgnoreCase);
        bool childMatches = hasFilter && node.Children.Any(c => DescendantMatches(c, _hierarchyFilter));

        if (matchesFilter || childMatches)
            yield return (node, depth);

        // Skip children if collapsed (unless filtering)
        if (!hasFilter && _collapsedNodes.Contains(node.Id))
            yield break;

        foreach (var child in node.Children)
        {
            foreach (var item in FlattenNode(child, depth + 1, hasFilter))
                yield return item;
        }
    }

    private static bool DescendantMatches(SceneNode node, string filter)
    {
        if (node.Name.Contains(filter, StringComparison.OrdinalIgnoreCase)) return true;
        return node.Children.Any(c => DescendantMatches(c, filter));
    }

    private void ToggleCollapse(SceneNode node)
    {
        if (!_collapsedNodes.Remove(node.Id))
            _collapsedNodes.Add(node.Id);
    }

    // --- Inline rename ---

    private void StartRename(SceneNode node) => _renamingNodeId = node.Id;

    private void FinishRename(SceneNode node, ChangeEventArgs e)
    {
        var newName = e.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(newName))
            node.Name = newName;
        _renamingNodeId = null;
    }

    // --- Context menu ---

    private void ShowContextMenu(MouseEventArgs e, SceneNode node)
    {
        _contextMenuNode = node;
        _contextMenuX = (int)e.ClientX;
        _contextMenuY = (int)e.ClientY;
        _contextMenuVisible = true;
        if (!IsSelected(node.Id)) SelectSingle(node);
    }

    private void ContextCut()
    {
        _contextMenuVisible = false;
        // Copy then delete
        _clipboard.Clear();
        foreach (var node in GetSelectedNodes())
            _clipboard.Add((node.Name, node.MeshType, node.MaterialPreset, node.Tag, node.Solid, node.Visible, node.Color, node.Transform.Position, node.Transform.Rotation, node.Transform.Scale, node.Light is { } l ? new PointLightData { Color = l.Color, Intensity = l.Intensity, Range = l.Range } : null, node.ImportedMeshData, node.ImportedMeshFileName));
        DeleteSelected();
    }

    private void ContextCopy()
    {
        _contextMenuVisible = false;
        _clipboard.Clear();
        foreach (var node in GetSelectedNodes())
            _clipboard.Add((node.Name, node.MeshType, node.MaterialPreset, node.Tag, node.Solid, node.Visible, node.Color, node.Transform.Position, node.Transform.Rotation, node.Transform.Scale, node.Light is { } l ? new PointLightData { Color = l.Color, Intensity = l.Intensity, Range = l.Range } : null, node.ImportedMeshData, node.ImportedMeshFileName));
    }

    private void ContextPaste()
    {
        _contextMenuVisible = false;
        if (_clipboard.Count == 0) return;
        _selectedIds.Clear();
        SceneNode? lastPasted = null;
        foreach (var c in _clipboard)
        {
            var node = new SceneNode(c.name + " (paste)") { MeshBuffers = ResolveMesh(c.meshType), MeshType = c.meshType, MaterialPreset = c.materialPreset, Tag = c.tag, Solid = c.solid, Visible = c.visible, Color = c.color, Light = c.light, ImportedMeshData = c.importedData, ImportedMeshFileName = c.importedFileName };
            node.Transform.Position = c.pos + new Vector3(1, 0, 1);
            node.Transform.Rotation = c.rot;
            node.Transform.Scale = c.scale;
            if (c.meshType == "Imported" && c.importedData != null && c.importedFileName != null)
                node.MeshBuffers = ResolveMeshFull("Imported", c.importedData, c.importedFileName);
            _undo.Do(new AddNodeAction(_scene, node));
            _selectedIds.Add(node.Id);
            lastPasted = node;
        }
        _scene.SelectedNode = lastPasted;
    }

    private void ContextDuplicate() { _contextMenuVisible = false; DuplicateSelected(); }
    private void ContextDelete() { _contextMenuVisible = false; DeleteSelected(); }
    private void ContextRename()
    {
        _contextMenuVisible = false;
        if (_contextMenuNode is not null) StartRename(_contextMenuNode);
    }

