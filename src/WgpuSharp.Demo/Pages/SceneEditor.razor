    private RenderFragment BuildButtons(string target) => __builder =>
    {
        <div class="build-actions">
            <label class="build-aot-label">
                <input type="checkbox" @bind="_buildAot" /> AOT (slower build, faster runtime)
            </label>
            <div class="build-btn-row">
                @if (_building)
                {
                    <button class="btn btn-sm btn-danger" @onclick="CancelBuild">Cancel Build</button>
                    <span class="build-spinner"></span>
                }
                else
                {
                    <button class="btn btn-sm btn-success" @onclick="() => RunBuild(target)">Build Now</button>
                }
            </div>
        </div>
    };

    private async Task RunBuild(string target)
    {
        if (_building) return;
        _building = true;
        _buildLog = "Preparing build...\n";
        StateHasChanged();

        // Write metadata to package.json before building
        if (_isElectron)
        {
            var meta = new { name = _pkgName, version = _pkgVersion, author = _pkgAuthor, email = _pkgAuthorEmail, homepage = _pkgHomepage };
            await JS.InvokeVoidAsync("WgpuSharpEditor.writePackageMetadata", meta);
        }

        // Save the current scene for the game runtime
        var gameSettings = new GameSettingsData
        {
            PlayerSpeed = _playerSpeed, JumpHeight = _jumpHeight, Gravity = _gravity,
            MaxPlayerHealth = _maxPlayerHealth, TimerEnabled = _timerEnabled, TimerMax = _levelTimerMax,
            WinCondition = _winCondition, StartMessage = _startMessage,
        };
        var sceneJson = SceneSerializer.Serialize(_scene, _settings, gameSettings);
        await JS.InvokeVoidAsync("WgpuSharpEditor.saveSceneForBuild", sceneJson);

        _buildLog = $"Running: build.sh {target} --game{(_buildAot ? " --aot" : "")}\n";
        StateHasChanged();

        await JS.InvokeVoidAsync("WgpuSharpEditor.runGameBuild", target, _buildAot);
    }

    private async Task CancelBuild()
    {
        await JS.InvokeVoidAsync("WgpuSharpEditor.cancelBuild");
        _building = false;
        _buildLog += "\nBuild cancelled.\n";
        StateHasChanged();
    }

    [JSInvokable]
    public void OnBuildOutput(string type, string text)
    {
        _buildLog += text;
        if (text.Contains("Build completed") || text.Contains("Build failed"))
            _building = false;
        InvokeAsync(StateHasChanged);
    }

    private async Task CopyBuildLog()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _buildLog);
        _buildLogCopied = true;
        StateHasChanged();
        await Task.Delay(1500);
        _buildLogCopied = false;
        StateHasChanged();
    }
}
