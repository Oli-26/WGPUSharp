@code {
    private string? _error;
    private string _gpuInfo = "";

    // Package guide
    private bool _showPackageGuide;
    private int _packageTab;
    private bool _isElectron;
    private bool _building;
    private bool _buildAot;
    private string _buildLog = "";
    private bool _buildLogCopied;

    // Package metadata (written to package.json before build)
    private string _pkgName = "My Game";
    private string _pkgAuthor = "";
    private string _pkgAuthorEmail = "";
    private string _pkgHomepage = "";
    private string _pkgVersion = "1.0.0";
    private bool _pkgMetadataLoaded;
    private float _fps;
    private GpuLoop? _loop;
    private GpuInput? _input;
    private GpuDevice? _device;
    private SceneRenderer? _renderer;
    private RenderBatch? _batch; // reused each frame
    private readonly Scene _scene = new();
    private readonly OrbitCamera _camera = new();
    private (float yaw, float pitch, float distance, Vector3 target)?[] _cameraBookmarks = new (float, float, float, Vector3)?[4];
    private readonly UndoStack _undo = new();
    private readonly SceneSettings _settings = new();
    private readonly FpsCamera _fpsCamera = new();
    private readonly FreeLookCamera _freeLookCamera = new();
    private bool _playMode;
    private bool _flyMode;

    // Play-mode game state
    private int _score;
    private int _totalCollectibles;
    private bool _hasEnemies;
    private float _playTime;
    private readonly HashSet<int> _collectedIds = new();

    // Trigger zone state
    private readonly HashSet<int> _activeTriggers = new();
    private string? _triggerMessage;
    private float _triggerMessageTimer;

    // Teleporter state
    private float _teleportCooldown;

    // Door-and-key state
    private readonly HashSet<string> _collectedKeys = new();

    // Enemy/health state
    private int _playerHealth;
    private float _damageCooldown;
    private float _damageZoneCooldown;

    // Checkpoint state
    private Vector3 _lastCheckpoint = Vector3.Zero;

    // Timer
    private float _levelTimer;
    private float _levelTimerMax = 60f;
    private bool _timerEnabled;

    // Game settings
    private float _playerSpeed = 5f;
    private float _jumpHeight = 6f;
    private float _gravity = 15f;
    private int _maxPlayerHealth = 100;
    private string _winCondition = "none";
    private string _startMessage = "";
    private float _startMessageTimer;
    private float _speedIndicatorTimer;

    // Script engine state
    private Dictionary<int, (List<ScriptCommand> cmds, ScriptState state, Vector3 startPos)> _scriptData = new();

    // Hierarchy drag-drop
    private int? _dragNodeId;

    // Hierarchy search/filter
    private string _hierarchyFilter = "";
    // Hierarchy collapse state
    private readonly HashSet<int> _collapsedNodes = new();
    // Inline rename
    private int? _renamingNodeId;

    // Context menu
    private bool _contextMenuVisible;
    private int _contextMenuX, _contextMenuY;
    private SceneNode? _contextMenuNode;

    // Resizable panels
    private int _sidebarWidth = 200;
    private int _inspectorWidth = 220;

    // Inspector collapsible sections
    private readonly HashSet<char> _collapsedInspectorSections = new();

    // Local/world space toggle
    private bool _localSpace;

    // Pause
    private bool _paused;

    // Keyboard shortcuts overlay
    private bool _showShortcuts;

    // Multi-selection
    private readonly HashSet<int> _selectedIds = new();

    // Copy-paste clipboard
    private List<(string name, string? meshType, string? materialPreset, NodeTag tag, bool solid, bool visible, Vector4 color, Vector3 pos, Quaternion rot, Vector3 scale, PointLightData? light, byte[]? importedData, string? importedFileName)> _clipboard = new();

    // Grid snap
    private bool _snapEnabled = true;
    private bool _showStats;
    private float _snapSize = 0.5f;
    private static readonly float[] SnapPresets = [0.1f, 0.25f, 0.5f, 1f, 2f];

    // Cached primitive meshes
    private MeshBuffers? _cubeMesh;
    private MeshBuffers? _sphereMesh;
    private MeshBuffers? _sphereLod1;
    private MeshBuffers? _sphereLod2;
    private MeshBuffers? _planeMesh;
    private MeshBuffers? _cylinderMesh;
    private MeshBuffers? _cylinderLod1;
    private MeshBuffers? _cylinderLod2;
    private int _nodeCounter;

    private enum PrimitiveType { Cube, Sphere, Plane, Cylinder }
    private MeshBuffers? _lightMesh; // small sphere for light icons

    private static readonly Vector4[] PaletteColors =
    [
        new(0.85f, 0.85f, 0.85f, 1), // light grey
        new(0.92f, 0.35f, 0.30f, 1), // red
        new(0.30f, 0.69f, 0.31f, 1), // green
        new(0.26f, 0.52f, 0.96f, 1), // blue
        new(1.00f, 0.76f, 0.03f, 1), // yellow
        new(0.61f, 0.35f, 0.71f, 1), // purple
        new(0.00f, 0.74f, 0.83f, 1), // cyan
        new(1.00f, 0.60f, 0.00f, 1), // orange
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            _isElectron = await JS.InvokeAsync<bool>("eval", "!!window.electronAPI");
            if (_isElectron)
            {
                var dotNetRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("WgpuSharpEditor.initBuildListener", dotNetRef);
            }

            var adapter = await Gpu.RequestAdapterAsync(JS);
            try { _gpuInfo = (await adapter.GetInfoAsync()).ToString(); } catch { _gpuInfo = "Unknown"; }
            _device = await adapter.RequestDeviceAsync();
            var canvas = await GpuCanvas.ConfigureAsync(_device, "gpu-canvas");
            _input = await GpuInput.InitAsync(_device, "gpu-canvas");

            // Create renderer
            _renderer = await SceneRenderer.CreateAsync(_device, canvas.Format);

            // Create cached primitive meshes + LOD variants
            _cubeMesh = await Primitives.Cube().CreateBuffersAsync(_device);
            _sphereMesh = await Primitives.Sphere().CreateBuffersAsync(_device);
            _sphereLod1 = await Primitives.Sphere(10, 20).CreateBuffersAsync(_device);
            _sphereLod2 = await Primitives.Sphere(6, 12).CreateBuffersAsync(_device);
            _planeMesh = await Primitives.Plane(4).CreateBuffersAsync(_device);
            _cylinderMesh = await Primitives.Cylinder().CreateBuffersAsync(_device);
            _cylinderLod1 = await Primitives.Cylinder(16).CreateBuffersAsync(_device);
            _cylinderLod2 = await Primitives.Cylinder(8).CreateBuffersAsync(_device);
            _lightMesh = await Primitives.Sphere(8, 16).CreateBuffersAsync(_device);

            // Setup default scene
            await SetupDefaultScene();

            // Match canvas backing size to display size
            await canvas.ResizeToDisplaySizeAsync();

            // Depth buffer
            var depthTexture = await canvas.CreateDepthTextureAsync(_device);
            var depthView = await depthTexture.CreateViewAsync();

            _loop = await Gpu.RunLoopAsync(_device, async (frame) =>
            {
                _fps = frame.Fps;

                // Handle canvas resize
                if (await canvas.ResizeToDisplaySizeAsync())
                {
                    await depthTexture.DisposeAsync();
                    depthTexture = await canvas.CreateDepthTextureAsync(_device);
                    depthView = await depthTexture.CreateViewAsync();
                }

                var input = await _input!.GetStateAsync();

                if (_playMode)
                {
                    // --- Play mode ---
                    _scene.UpdateTransforms();
                    float dt = _paused ? 0 : frame.DeltaTime;
                    _playTime += dt;

                    // HUD timers
                    if (_startMessageTimer > 0) _startMessageTimer -= dt;
                    if (_speedIndicatorTimer > 0) _speedIndicatorTimer -= dt;

                    // Escape exits play mode
                    if (input.WasKeyPressed("Escape"))
                    {
                        ExitPlayMode();
                        _scene.UpdateTransforms();
                        // Skip to editor render below
                    }

                    if (_playMode)
                    {
                    if (_flyMode)
                    {
                        // --- Fly mode: free camera, animations run but no player interaction ---
                        if (!_paused) _freeLookCamera.ProcessInput(input, dt);
                        if (input.WheelDelta != 0) _speedIndicatorTimer = 1.5f;
                        UpdateMovingPlatforms(dt);
                        ExecuteScripts(dt);
                        _scene.UpdateTransforms();
                        _scene.RefreshCaches(frame.FrameIndex);

                        _batch ??= new RenderBatch(_device); _batch.Reset(); var batch = _batch;
                        var colorView = batch.GetCurrentTextureView(canvas);
                        _renderer!.Render(batch, _scene, _freeLookCamera, canvas, colorView, depthView, _settings);
                        await batch.FlushAsync();
                    }
                    else
                    {
                        // --- FPS mode: physics camera + full gameplay ---
                        if (!_paused) _fpsCamera.ProcessInput(input, dt, _scene);
                        if (input.WheelDelta != 0) _speedIndicatorTimer = 1.5f;

                        UpdateCollectibles(dt);
                        CheckTriggers(dt);
                        UpdateEnemies(dt);
                        UpdateDoorsAndKeys(dt);
                        UpdateTeleporters();
                        UpdateDamageZones(dt);
                        UpdateHealthPickups();
                        UpdateMovingPlatforms(dt);
                        CheckCheckpoints();
                        UpdateNPCs();
                        ExecuteScripts(dt);

                        if (_timerEnabled)
                        {
                            _levelTimer -= dt;
                            if (_levelTimer <= 0) { _levelTimer = 0; _playerHealth = 0; }
                        }

                        if (_playerHealth <= 0 && _damageCooldown <= 0)
                        {
                            _playerHealth = 50;
                            _fpsCamera.Position = _lastCheckpoint + new Vector3(0, FpsCamera.EyeHeight, 0);
                            _damageCooldown = 2f;
                        }

                        _scene.UpdateTransforms();
                        _scene.RefreshCaches(frame.FrameIndex);

                        _batch ??= new RenderBatch(_device); _batch.Reset(); var batch = _batch;
                        var colorView = batch.GetCurrentTextureView(canvas);
                        _renderer!.Render(batch, _scene, _fpsCamera, canvas, colorView, depthView, _settings);
                        await batch.FlushAsync();

                        await DrawMinimap();
                    }
                    } // end if (_playMode) gameplay+render
                }
                // Tick skeletal animations (both editor and play mode)
                foreach (var node in _scene.AllNodesCached)
                    node.AnimationPlayer?.Update(frame.DeltaTime);

                if (!_playMode)
                {
                    // --- Editor mode: orbit camera + gizmo + picking ---
                    var gizmo = _renderer!.Gizmo!;
                    bool gizmoActive = ProcessGizmo(input, canvas, gizmo);

                    if (!gizmoActive)
                    {
                        _camera.ProcessInput(input, frame.DeltaTime);
                        ProcessPicking(input, canvas);
                        ProcessBoxSelect(input, canvas);
                    }

                    ProcessShortcuts(input);

                    _scene.UpdateTransforms();
                    _scene.RefreshCaches(frame.FrameIndex);

                    _batch ??= new RenderBatch(_device); _batch.Reset(); var batch = _batch;
                    var colorView = batch.GetCurrentTextureView(canvas);
                    _renderer!.Render(batch, _scene, _camera, canvas, colorView, depthView, _settings, _selectedIds);
                    await batch.FlushAsync();
                }

                if (frame.FrameIndex % 20 == 0) StateHasChanged();
            });

            StateHasChanged();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            StateHasChanged();
        }
    }

