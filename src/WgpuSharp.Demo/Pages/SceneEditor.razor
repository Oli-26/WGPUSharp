        for (int i = 0; i < 5; i++)
        {
            var bx = 33f - i * 3;
            var bpColor = new Vector4(0.6f, 0.5f, 0.35f, 0.8f);
            AddBox($"Breakable {i + 1}", new Vector3(bx, 6f, -30), new Vector3(2, 0.3f, 2), bpColor);
        }

        AddEnemy("Sentry", new Vector3(25, 6.5f, -30));

        // Finish
        AddBox("Finish Platform", new Vector3(18, 6f, -30), new Vector3(5, 0.5f, 5), new Vector4(0.3f, 0.6f, 0.4f, 1));
        AddTrigger("Finish", new Vector3(18, 7f, -30), new Vector3(4, 2, 4));

        // Collectibles along the course
        AddCollectible("Coin 1", new Vector3(5, 0.8f, -3), PaletteColors[4]);
        AddCollectible("Coin 2", new Vector3(22, 1.3f, 1), PaletteColors[4]);
        AddCollectible("Coin 3", new Vector3(34, 1.5f, 0), PaletteColors[4]);
        AddCollectible("Coin 4", new Vector3(38, 4f, -20), PaletteColors[4]);
        AddCollectible("Coin 5", new Vector3(25, 6.8f, -30), PaletteColors[4]);

        // Lighting
        AddLightNode(new Vector3(0, 4f, 0), new Vector3(1f, 0.9f, 0.7f), 3f, 18f);
        AddLightNode(new Vector3(22, 4f, 0), new Vector3(1f, 0.4f, 0.3f), 2.5f, 15f);
        AddLightNode(new Vector3(38, 4f, -10), new Vector3(0.5f, 0.7f, 1f), 2.5f, 15f);
        AddLightNode(new Vector3(38, 9f, -30), new Vector3(0.3f, 1f, 0.5f), 3f, 18f);
    }

