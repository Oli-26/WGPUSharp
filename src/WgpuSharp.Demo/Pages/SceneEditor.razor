@page "/editor"
@using System.Numerics
@using WgpuSharp.Core
@using WgpuSharp.Commands
@using WgpuSharp.Mesh
@using WgpuSharp.Pipeline
@using WgpuSharp.Resources
@using WgpuSharp.Scene
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>WgpuSharp — Scene Editor</PageTitle>

<div class="editor-root">
    @* --- Left: Scene hierarchy --- *@
    <div class="editor-sidebar @(_playMode ? "panel-dimmed" : "")" style="width: @(_sidebarWidth)px; min-width: 120px;">
        <div class="sidebar-header">
            <strong>Scene</strong>
            <span class="node-count-badge">@_scene.NodeCount</span>
        </div>
        <div class="hierarchy-search">
            <input type="text" class="hierarchy-search-input" placeholder="Filter nodes..."
                   @bind="_hierarchyFilter" @bind:event="oninput" />
        </div>
        <div class="sidebar-content">
            @foreach (var (node, depth) in GetFlatHierarchy())
            {
                var n = node; // capture for lambda
                bool isSelected = IsSelected(n.Id);
                bool hasChildren = n.Children.Count > 0;
                bool isCollapsed = _collapsedNodes.Contains(n.Id);
                <div class="hierarchy-node @(isSelected ? "selected" : "") @(_dragNodeId == n.Id ? "dragging" : "")"
                     style="padding-left: @(8 + depth * 16)px"
                     draggable="true"
                     @ondragstart="() => _dragNodeId = n.Id"
                     @ondragover:preventDefault="true"
                     @ondrop="() => ReparentNode(n)"
                     @ondragend="() => _dragNodeId = null"
                     @onclick="e => { if (e.ShiftKey) ToggleSelect(n); else SelectSingle(n); }"
                     @ondblclick="() => StartRename(n)"
                     @oncontextmenu="e => ShowContextMenu(e, n)" @oncontextmenu:preventDefault="true">
                    @if (hasChildren)
                    {
                        <span class="hierarchy-toggle @(isCollapsed ? "" : "open")"
                              @onclick="() => ToggleCollapse(n)" @onclick:stopPropagation="true"></span>
                    }
                    else
                    {
                        <span class="hierarchy-toggle-spacer"></span>
                    }
                    <span class="hierarchy-icon">@GetNodeIcon(n)</span>
                    @if (_renamingNodeId == n.Id)
                    {
                        <input type="text" class="rename-input" value="@n.Name"
                               @onchange="e => FinishRename(n, e)" @onblur="() => _renamingNodeId = null"
                               autofocus />
                    }
                    else
                    {
                        <span class="@(n.Visible ? "" : "text-muted")">@n.Name</span>
                    }
                    @if (n.Locked) { <span class="hierarchy-lock" title="Locked">L</span> }
                </div>
            }
            <div class="hierarchy-node" style="padding: 4px 8px; color: #555; font-style: italic;"
                 @ondragover:preventDefault="true" @ondrop="ReparentToRoot">(drop here for root)</div>
        </div>
        <div class="sidebar-actions">
            <button class="btn btn-sm btn-outline-light" @onclick="() => AddPrimitive(PrimitiveType.Cube)">+ Cube</button>
            <button class="btn btn-sm btn-outline-light" @onclick="() => AddPrimitive(PrimitiveType.Sphere)">+ Sphere</button>
            <button class="btn btn-sm btn-outline-light" @onclick="() => AddPrimitive(PrimitiveType.Plane)">+ Plane</button>
            <button class="btn btn-sm btn-outline-light" @onclick="() => AddPrimitive(PrimitiveType.Cylinder)">+ Cylinder</button>
            <button class="btn btn-sm btn-outline-warning" @onclick="AddLight">+ Light</button>
            <button class="btn btn-sm btn-outline-info" @onclick="ImportMesh">Import</button>
        </div>
        <div class="sidebar-actions" style="border-top: 1px solid #2a2a3a;">
            <div class="sidebar-section-label">Prefabs</div>
            <div class="sidebar-btn-grid">
                <button class="btn btn-sm btn-outline-success" @onclick="@(() => AddPrefab("playerstart"))">Player Start</button>
                <button class="btn btn-sm btn-outline-warning" @onclick="@(() => AddPrefab("cointrail"))">Coin Trail</button>
                <button class="btn btn-sm btn-outline-info" @onclick="@(() => AddPrefab("movingplatform"))">Moving Plat</button>
                <button class="btn btn-sm btn-outline-light" @onclick="@(() => AddPrefab("turret"))">Turret</button>
                <button class="btn btn-sm btn-outline-warning" @onclick="@(() => AddPrefab("gatekey"))">Gate &amp; Key</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="@(() => AddPrefab("enemypatrol"))">Enemy Patrol</button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => AddPrefab("lightpost"))">Light Post</button>
            </div>
        </div>
        <div class="sidebar-actions" style="border-top: 1px solid #2a2a3a;">
            <button class="btn btn-sm btn-outline-secondary" @onclick="SaveScene">Save</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="LoadScene">Load</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="TakeScreenshot">Screenshot</button>
            <button class="btn btn-sm btn-outline-success" @onclick="() => _showPackageGuide = true">Package</button>
        </div>
        <div class="sidebar-actions" style="border-top: 1px solid #2a2a3a;">
            <select class="snap-select" style="width: 80px;" @bind="_selectedTemplate">
                @foreach (var t in SceneTemplates)
                {
                    <option value="@t">@t</option>
                }
            </select>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => LoadTemplate(_selectedTemplate)">New Scene</button>
        </div>
    </div>

    @* --- Context menu --- *@
    @if (_contextMenuVisible)
    {
        <div class="context-menu-backdrop" @onclick="() => _contextMenuVisible = false"></div>
        <div class="context-menu" style="left: @(_contextMenuX)px; top: @(_contextMenuY)px;">
            <div class="context-menu-item" @onclick="ContextCut">Cut</div>
            <div class="context-menu-item" @onclick="ContextCopy">Copy</div>
            <div class="context-menu-item" @onclick="ContextPaste" style="@(_clipboard.Count == 0 ? "opacity:0.4;pointer-events:none" : "")">Paste</div>
            <div class="context-menu-divider"></div>
            <div class="context-menu-item" @onclick="ContextDuplicate">Duplicate</div>
            <div class="context-menu-item" @onclick="ContextRename">Rename</div>
            <div class="context-menu-divider"></div>
            <div class="context-menu-item context-menu-danger" @onclick="ContextDelete">Delete</div>
        </div>
    }

    @* --- Center: Viewport --- *@
    <div class="editor-viewport">
        @if (_error is not null)
        {
            <div class="alert alert-danger m-2">@_error</div>
        }
        <div class="viewport-toolbar @(_playMode ? "play-toolbar" : "")">
            @if (!_playMode)
            {
                <span class="toolbar-buttons history-group">
                    <div class="history-btn-wrap">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _undo.Undo()" disabled="@(!_undo.CanUndo)" title="@(_undo.UndoDescription ?? "Nothing to undo")">Undo</button>
                        @if (_undo.UndoCount > 0)
                        {
                            <div class="history-dropdown">
                                @for (int i = _undo.UndoHistory.Count - 1; i >= Math.Max(0, _undo.UndoHistory.Count - 10); i--)
                                {
                                    var idx = i;
                                    <div class="history-item">@_undo.UndoHistory[idx].Description</div>
                                }
                            </div>
                        }
                    </div>
                    <div class="history-btn-wrap">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _undo.Redo()" disabled="@(!_undo.CanRedo)" title="@(_undo.RedoDescription ?? "Nothing to redo")">Redo</button>
                        @if (_undo.RedoCount > 0)
                        {
                            <div class="history-dropdown">
                                @for (int i = _undo.RedoHistory.Count - 1; i >= Math.Max(0, _undo.RedoHistory.Count - 10); i--)
                                {
                                    var idx = i;
                                    <div class="history-item">@_undo.RedoHistory[idx].Description</div>
                                }
                            </div>
                        }
                    </div>
                </span>
                <span class="toolbar-buttons tool-group">
                    <button class="btn btn-sm @(GizmoModeIs(GizmoMode.Translate) ? "btn-tool-on" : "btn-outline-secondary")"
                            @onclick="() => SetGizmoMode(GizmoMode.Translate)" title="Move tool (W)">Move</button>
                    <button class="btn btn-sm @(GizmoModeIs(GizmoMode.Rotate) ? "btn-tool-on" : "btn-outline-secondary")"
                            @onclick="() => SetGizmoMode(GizmoMode.Rotate)" title="Rotate tool (E)">Rotate</button>
                    <button class="btn btn-sm @(GizmoModeIs(GizmoMode.Scale) ? "btn-tool-on" : "btn-outline-secondary")"
                            @onclick="() => SetGizmoMode(GizmoMode.Scale)" title="Scale tool (R)">Scale</button>
                </span>
                <button class="btn btn-sm @(_localSpace ? "btn-snap-on" : "btn-outline-secondary")"
                        @onclick="() => _localSpace = !_localSpace" title="Local / World space (L)">@(_localSpace ? "Local" : "World")</button>
                <span class="toolbar-buttons snap-group">
                    <button class="btn btn-sm @(_snapEnabled ? "btn-snap-on" : "btn-outline-secondary")"
                            @onclick="() => _snapEnabled = !_snapEnabled"
                            title="Toggle grid snap (G)">Snap</button>
                    <select class="snap-select" @bind="_snapSize" title="Snap grid size">
                        @foreach (var s in SnapPresets)
                        {
                            <option value="@s">@s.ToString("G")</option>
                        }
                    </select>
                </span>
                <button class="btn btn-sm @(GroundEnabled() ? "btn-snap-on" : "btn-outline-secondary")"
                        @onclick="ToggleGround" title="Toggle ground plane">Floor</button>
                <button class="btn btn-sm btn-play" @onclick="EnterPlayMode">Play</button>
                <span class="text-muted small toolbar-hints">
                    @if (_fps > 0) { <text>@_fps.ToString("F0") FPS</text> }
                    | <span class="shortcut-hint" @onclick="() => _showShortcuts = true" title="Click for full shortcut list">?=help</span>
                </span>
            }
            else
            {
                <button class="btn btn-sm btn-stop" @onclick="ExitPlayMode">Stop</button>
                <button class="btn btn-sm @(_paused ? "btn-pause-on" : "btn-outline-warning")" @onclick="() => _paused = !_paused">@(_paused ? "Resume" : "Pause")</button>
                <span class="toolbar-buttons tool-group">
                    <button class="btn btn-sm @(!_flyMode ? "btn-tool-on" : "btn-outline-secondary")" @onclick="SwitchToFps">FPS</button>
                    <button class="btn btn-sm @(_flyMode ? "btn-tool-on" : "btn-outline-secondary")" @onclick="SwitchToFly">Fly</button>
                </span>
                <span class="play-label">@(_paused ? "PAUSED" : _flyMode ? "FLY MODE" : "FPS MODE")</span>
                <span class="text-muted small">
                    @if (_fps > 0) { <text>@_fps.ToString("F0") FPS</text> }
                    @if (_flyMode)
                    {
                        <text>| WASD=move  Mouse=look  Space=up  Shift=down  Scroll=speed  Esc=stop</text>
                    }
                    else
                    {
                        <text>| WASD=move  Mouse=look  Space=jump  Scroll=speed  Esc=stop</text>
                    }
                </span>
            }
        </div>
        <div style="position: relative;">
            <canvas id="gpu-canvas" width="800" height="600"
                    style="display: block; width: 100%; height: calc(100vh - 3.5rem - 28px); cursor: crosshair;"></canvas>
            @if (_playMode && !_flyMode && _totalCollectibles > 0)
            {
                <div class="play-hud">
                    <span class="hud-score">@_score / @_totalCollectibles</span>
                    @if (_score >= _totalCollectibles)
                    {
                        <span class="hud-win">ALL COLLECTED!</span>
                    }
                </div>
            }
            @if (_playMode && _triggerMessage is not null)
            {
                <div class="trigger-message">@_triggerMessage</div>
            }
            @if (_playMode && !_flyMode && _hasEnemies)
            {
                <div class="health-bar">
                    <div class="health-fill" style="width: @((int)(100.0 * _playerHealth / _maxPlayerHealth))%"></div>
                    <span class="health-text">@_playerHealth / @_maxPlayerHealth HP</span>
                </div>
                @if (_playerHealth <= 0)
                {
                    <div class="game-over">GAME OVER</div>
                }
            }
            @if (_playMode && !_flyMode)
            {
                <canvas id="minimap-canvas" width="150" height="150" style="position: absolute; bottom: 50px; right: 10px; border: 1px solid #444; border-radius: 4px; pointer-events: none; z-index: 10; background: rgba(0,0,0,0.5);"></canvas>
            }
            @if (_playMode && !_flyMode && _timerEnabled)
            {
                <div class="timer-hud">@TimeSpan.FromSeconds(Math.Max(0, _levelTimer)).ToString(@"m\:ss")</div>
            }
            @if (_playMode)
            {
                <div class="play-crosshair">+</div>
            }
            @if (_playMode && _winCondition != "none")
            {
                <div class="play-objective">@GetObjectiveText()</div>
            }
            @if (_playMode && _speedIndicatorTimer > 0)
            {
                <div class="play-speed-indicator">Speed: @_fpsCamera.MoveSpeed.ToString("F1")</div>
            }
            @if (_playMode && _startMessageTimer > 0 && !string.IsNullOrEmpty(_startMessage))
            {
                <div class="play-start-message">@_startMessage</div>
            }
            @if (_importing)
            {
                <div class="import-overlay">
                    <div class="import-dialog">
                        <div class="import-title">Importing Model</div>
                        <div class="import-phase" id="import-progress-label">@(_importPhase ?? "Working...")</div>
                        <div class="import-bar-track">
                            <div class="import-bar-fill" id="import-progress-bar" style="width: @(_importPercent)%"></div>
                        </div>
                        <div class="import-percent">@_importPercent%</div>
                    </div>
                </div>
            }
            @if (_showStats)
            {
                <div class="stats-overlay">
                    <div>GPU: @_gpuInfo</div>
                    <div>FPS: @_fps.ToString("F0")</div>
                    <div>Nodes: @_scene.NodeCount</div>
                    <div>Lights: @_scene.LightCount</div>
                    <div>Selected: @_selectedIds.Count</div>
                    @if (_playMode && _flyMode)
                    {
                        <div>Pos: @_freeLookCamera.Position.X.ToString("F1"), @_freeLookCamera.Position.Y.ToString("F1"), @_freeLookCamera.Position.Z.ToString("F1")</div>
                        <div>Mode: Fly</div>
                    }
                    else if (_playMode)
                    {
                        <div>Pos: @_fpsCamera.Position.X.ToString("F1"), @_fpsCamera.Position.Y.ToString("F1"), @_fpsCamera.Position.Z.ToString("F1")</div>
                        <div>Grounded: @_fpsCamera.IsGrounded</div>
                    }
                </div>
            }
            @if (!_playMode && _snapEnabled)
            {
                <div class="snap-indicator">Snap: @_snapSize.ToString("G")</div>
            }
        </div>
    </div>

    @* --- Right: Inspector --- *@
    <div class="editor-inspector @(_playMode ? "panel-dimmed" : "")" style="width: @(_inspectorWidth)px; min-width: 120px;">
        <div class="sidebar-header">
            <strong>Inspector</strong>
        </div>
        @if (_selectedIds.Count > 1)
        {
            <div class="inspector-content">
                <div class="prop-group">
                    <label>Selection</label>
                    <span>@_selectedIds.Count objects selected</span>
                </div>
                <div class="prop-group mt-3">
                    <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">Delete All</button>
                    <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="DuplicateSelected">Duplicate All</button>
                </div>
                <div class="prop-group">
                    <label>Align</label>
                    <div style="display: flex; gap: 3px; flex-wrap: wrap;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AlignSelected(0, false)">Left</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AlignSelected(0, true)">Right</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AlignSelected(1, false)">Bottom</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AlignSelected(1, true)">Top</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AlignSelected(2, false)">Front</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => AlignSelected(2, true)">Back</button>
                    </div>
                </div>
                <div class="prop-group">
                    <label>Distribute</label>
                    <div style="display: flex; gap: 3px;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => DistributeSelected(0)">X</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => DistributeSelected(1)">Y</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => DistributeSelected(2)">Z</button>
                    </div>
                </div>
            </div>
        }
        else if (_scene.SelectedNode is { } sel)
        {
            <div class="inspector-content">
                <div class="prop-group">
                    <label>Name</label>
                    <input type="text" class="form-control form-control-sm" @bind="sel.Name" @bind:event="oninput" />
                </div>

                @* --- Properties section --- *@
                <div class="inspector-section-header" @onclick="() => ToggleInspectorSection('p')">
                    <span class="inspector-toggle">@(InspectorSectionOpen('p') ? "v" : ">")</span> Properties
                </div>
                @if (InspectorSectionOpen('p'))
                {
                    <div class="prop-group">
                        <label>Visible</label>
                        <input type="checkbox" @bind="sel.Visible" />
                    </div>
                    <div class="prop-group">
                        <label>Solid</label>
                        <input type="checkbox" @bind="sel.Solid" />
                    </div>
                    <div class="prop-group">
                        <label>Locked</label>
                        <input type="checkbox" @bind="sel.Locked" />
                    </div>
                    <div class="prop-group">
                        <label>Tag</label>
                        <select class="form-control form-control-sm" @bind="sel.Tag">
                            @foreach (var t in Enum.GetValues<NodeTag>())
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                }

                <div class="inspector-divider"></div>

                @* --- Transform section --- *@
                <div class="inspector-section-header" @onclick="() => ToggleInspectorSection('t')">
                    <span class="inspector-toggle">@(InspectorSectionOpen('t') ? "v" : ">")</span> Transform
                </div>
                @if (InspectorSectionOpen('t'))
                {
                    <div class="prop-group">
                        <label>Position</label>
                        <div class="vec3-row">
                            <div class="vec3-field"><span>X</span><input type="number" step="0.1" value="@sel.Transform.Position.X.ToString("F2")" @onchange="e => SetPosition(sel, 0, e)" /></div>
                            <div class="vec3-field"><span>Y</span><input type="number" step="0.1" value="@sel.Transform.Position.Y.ToString("F2")" @onchange="e => SetPosition(sel, 1, e)" /></div>
                            <div class="vec3-field"><span>Z</span><input type="number" step="0.1" value="@sel.Transform.Position.Z.ToString("F2")" @onchange="e => SetPosition(sel, 2, e)" /></div>
                        </div>
                    </div>
                    <div class="prop-group">
                        <label>Rotation (deg)</label>
                        @{ var euler = sel.Transform.EulerAngles * (180f / MathF.PI); }
                        <div class="vec3-row">
                            <div class="vec3-field"><span>X</span><input type="number" step="1" value="@euler.X.ToString("F1")" @onchange="e => SetRotation(sel, 0, e)" /></div>
                            <div class="vec3-field"><span>Y</span><input type="number" step="1" value="@euler.Y.ToString("F1")" @onchange="e => SetRotation(sel, 1, e)" /></div>
                            <div class="vec3-field"><span>Z</span><input type="number" step="1" value="@euler.Z.ToString("F1")" @onchange="e => SetRotation(sel, 2, e)" /></div>
                        </div>
                    </div>
                    <div class="prop-group">
                        <label>Scale</label>
                        <div class="vec3-row">
                            <div class="vec3-field"><span>X</span><input type="number" step="0.1" value="@sel.Transform.Scale.X.ToString("F2")" @onchange="e => SetScale(sel, 0, e)" /></div>
                            <div class="vec3-field"><span>Y</span><input type="number" step="0.1" value="@sel.Transform.Scale.Y.ToString("F2")" @onchange="e => SetScale(sel, 1, e)" /></div>
                            <div class="vec3-field"><span>Z</span><input type="number" step="0.1" value="@sel.Transform.Scale.Z.ToString("F2")" @onchange="e => SetScale(sel, 2, e)" /></div>
                        </div>
                    </div>
                }

                <div class="inspector-divider"></div>

                @* --- Material section --- *@
                <div class="inspector-section-header" @onclick="() => ToggleInspectorSection('m')">
                    <span class="inspector-toggle">@(InspectorSectionOpen('m') ? "v" : ">")</span> Material
                </div>
                @if (InspectorSectionOpen('m'))
                {
                    <div class="prop-group">
                        <label>Preset</label>
                        <select class="form-control form-control-sm" value="@(sel.MaterialPreset ?? "")" @onchange="e => ApplyMaterial(sel, e)">
                            <option value="">Custom</option>
                            @foreach (var preset in MaterialPresets.All)
                            {
                                <option value="@preset.Name">@preset.Name</option>
                            }
                        </select>
                    </div>
                    <div class="prop-group">
                        <label>Color</label>
                        <input type="color"
                               value="@ColorToHex(sel.Color)"
                               @onchange="e => SetNodeColor(sel, e)" />
                    </div>
                }

                @if (sel.Light is { } light)
                {
                    <div class="inspector-divider"></div>
                    <div class="inspector-section-header" @onclick="() => ToggleInspectorSection('l')">
                        <span class="inspector-toggle">@(InspectorSectionOpen('l') ? "v" : ">")</span> Light
                    </div>
                    @if (InspectorSectionOpen('l'))
                    {
                        <div class="prop-group">
                            <label>Light Color</label>
                            <input type="color"
                                   value="@Vec3ToHex(light.Color)"
                                   @onchange="e => SetLightColor(light, e)" />
                        </div>
                        <div class="prop-group">
                            <label>Intensity</label>
                            <input type="range" min="0.5" max="10" step="0.5"
                                   value="@light.Intensity.ToString("F1")"
                                   @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) light.Intensity = v; }" />
                            <span class="text-muted small">@light.Intensity.ToString("F1")</span>
                        </div>
                        <div class="prop-group">
                            <label>Range</label>
                            <input type="range" min="1" max="30" step="1"
                                   value="@light.Range.ToString("F0")"
                                   @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) light.Range = v; }" />
                            <span class="text-muted small">@light.Range.ToString("F0")</span>
                        </div>
                    }
                }

                @if (sel.AnimationPlayer is { } anim)
                {
                    <div class="inspector-divider"></div>
                    <div class="inspector-section-header" @onclick="() => ToggleInspectorSection('a')">
                        <span class="inspector-toggle">@(InspectorSectionOpen('a') ? "v" : ">")</span> Animation
                    </div>
                    @if (InspectorSectionOpen('a'))
                    {
                        @if (anim.Clips.Length > 0)
                        {
                            <div class="prop-group">
                                <label>Clip</label>
                                <select class="form-control form-control-sm"
                                        value="@anim.CurrentClipIndex"
                                        @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) anim.SetClip(v); }">
                                    @for (int ci = 0; ci < anim.Clips.Length; ci++)
                                    {
                                        var clipIdx = ci;
                                        <option value="@clipIdx">@(anim.Clips[clipIdx].Name)</option>
                                    }
                                </select>
                            </div>
                        }
                        <div class="prop-group">
                            <label>Controls</label>
                            <div style="display: flex; gap: 3px;">
                                <button class="btn btn-sm btn-outline-success" @onclick="() => anim.Play()">Play</button>
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => anim.Pause()">Pause</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => anim.Stop()">Stop</button>
                            </div>
                        </div>
                        <div class="prop-group">
                            <label>Speed</label>
                            <input type="range" min="0" max="3" step="0.1"
                                   value="@anim.Speed.ToString("F1")"
                                   @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) anim.Speed = v; }" />
                            <span class="text-muted small">@anim.Speed.ToString("F1")x</span>
                        </div>
                        <div class="prop-group">
                            <label>Loop</label>
                            <input type="checkbox" checked="@anim.Loop"
                                   @onchange="e => anim.Loop = (bool)(e.Value ?? false)" />
                        </div>
                        @if (anim.CurrentClip is { } clip)
                        {
                            <div class="prop-group">
                                <label>Time</label>
                                <input type="range" min="0" max="@clip.Duration.ToString("F2")" step="0.01"
                                       value="@anim.Time.ToString("F2")"
                                       @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) anim.Time = v; }" />
                                <span class="text-muted small">@anim.Time.ToString("F2") / @clip.Duration.ToString("F2")s</span>
                            </div>
                        }
                        <div class="prop-group">
                            <span class="text-muted small">Joints: @anim.Skeleton.JointCount</span>
                        </div>
                    }
                }

                <div class="inspector-divider"></div>

                @* --- Script section --- *@
                <div class="inspector-section-header" @onclick="() => ToggleInspectorSection('s')">
                    <span class="inspector-toggle">@(InspectorSectionOpen('s') ? "v" : ">")</span> Script
                </div>
                @if (InspectorSectionOpen('s'))
                {
                    <div class="prop-group">
                        <select class="form-control form-control-sm" style="margin-bottom: 4px;"
                                @onchange="e => ApplyScriptTemplate(sel, e)">
                            <option value="">-- Insert template --</option>
                            @foreach (var t in ScriptTemplates)
                            {
                                <option value="@t.name">@t.name</option>
                            }
                        </select>
                        <textarea class="form-control form-control-sm script-editor"
                                  rows="5" spellcheck="false"
                                  placeholder="// Select a template above or write commands"
                                  @bind="sel.Script" @bind:event="onchange"></textarea>
                    </div>
                }

                <div class="prop-group mt-3">
                    <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">Delete</button>
                    <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="DuplicateSelected">Duplicate</button>
                </div>
            </div>
        }
        else
        {
            <div class="inspector-content">
                <div class="prop-group">
                    <label class="section-label">Scene Settings</label>
                </div>

                <div class="prop-group">
                    <label>Sky Zenith</label>
                    <input type="color" value="@Vec3ToHex(_settings.SkyZenith)"
                           @onchange="e => _settings.SkyZenith = HexToVec3(e)" />
                </div>
                <div class="prop-group">
                    <label>Sky Horizon</label>
                    <input type="color" value="@Vec3ToHex(_settings.SkyHorizon)"
                           @onchange="e => _settings.SkyHorizon = HexToVec3(e)" />
                </div>
                <div class="prop-group">
                    <label>Sky Ground</label>
                    <input type="color" value="@Vec3ToHex(_settings.SkyGround)"
                           @onchange="e => _settings.SkyGround = HexToVec3(e)" />
                </div>

                <div class="prop-group">
                    <label>Sun Color</label>
                    <input type="color" value="@Vec3ToHex(_settings.SunColor)"
                           @onchange="e => _settings.SunColor = HexToVec3(e)" />
                </div>
                <div class="prop-group">
                    <label>Sun Intensity</label>
                    <input type="range" min="0" max="2" step="0.05"
                           value="@_settings.SunIntensity.ToString("F2")"
                           @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) _settings.SunIntensity = v; }" />
                    <span class="text-muted small">@_settings.SunIntensity.ToString("F2")</span>
                </div>

                <div class="prop-group">
                    <label>Ambient Color</label>
                    <input type="color" value="@Vec3ToHex(_settings.AmbientColor)"
                           @onchange="e => _settings.AmbientColor = HexToVec3(e)" />
                </div>

                <div class="prop-group">
                    <label>Fog Color</label>
                    <input type="color" value="@Vec3ToHex(_settings.FogColor)" @onchange="e => _settings.FogColor = HexToVec3(e)" />
                </div>
                <div class="prop-group">
                    <label>Fog Start</label>
                    <input type="range" min="5" max="100" step="5" value="@_settings.FogStart.ToString("F0")" @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) _settings.FogStart = v; }" />
                    <span class="text-muted small">@_settings.FogStart.ToString("F0")</span>
                </div>
                <div class="prop-group">
                    <label>Fog End</label>
                    <input type="range" min="10" max="200" step="5" value="@_settings.FogEnd.ToString("F0")" @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) _settings.FogEnd = v; }" />
                    <span class="text-muted small">@_settings.FogEnd.ToString("F0")</span>
                </div>

                <div class="prop-group" style="margin-top: 12px;">
                    <label class="section-label">Gameplay</label>
                </div>
                <div class="prop-group">
                    <label>Level Timer</label>
                    <input type="checkbox" @bind="_timerEnabled" /> Enable
                </div>
                @if (_timerEnabled)
                {
                    <div class="prop-group">
                        <label>Time Limit</label>
                        <input type="range" min="10" max="300" step="10" value="@_levelTimerMax.ToString("F0")" @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) _levelTimerMax = v; }" />
                        <span class="text-muted small">@_levelTimerMax.ToString("F0")s</span>
                    </div>
                }
                <div class="prop-group">
                    <label>Player Speed</label>
                    <input type="range" min="1" max="20" step="0.5" value="@_playerSpeed.ToString("F1")" @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) _playerSpeed = v; }" />
                    <span class="text-muted small">@_playerSpeed.ToString("F1")</span>
                </div>
                <div class="prop-group">
                    <label>Jump Height</label>
                    <input type="range" min="1" max="15" step="0.5" value="@_jumpHeight.ToString("F1")" @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) _jumpHeight = v; }" />
                    <span class="text-muted small">@_jumpHeight.ToString("F1")</span>
                </div>
                <div class="prop-group">
                    <label>Gravity</label>
                    <input type="range" min="5" max="30" step="0.5" value="@_gravity.ToString("F1")" @oninput="e => { if (float.TryParse(e.Value?.ToString(), out var v)) _gravity = v; }" />
                    <span class="text-muted small">@_gravity.ToString("F1")</span>
                </div>
                <div class="prop-group">
                    <label>Player Health</label>
                    <input type="range" min="50" max="500" step="10" value="@_maxPlayerHealth" @oninput="e => { if (int.TryParse(e.Value?.ToString(), out var v)) _maxPlayerHealth = v; }" />
                    <span class="text-muted small">@_maxPlayerHealth</span>
                </div>
                <div class="prop-group">
                    <label>Win Condition</label>
                    <select class="prop-select" @bind="_winCondition">
                        <option value="none">None</option>
                        <option value="collect_all">Collect All</option>
                        <option value="reach_goal">Reach Goal</option>
                        <option value="timer">Timer</option>
                    </select>
                </div>
                <div class="prop-group">
                    <label>Starting Message</label>
                    <input type="text" class="prop-text-input" placeholder="Message shown when play starts..." @bind="_startMessage" />
                </div>
            </div>
        }
    </div>
</div>

@if (_showPackageGuide)
{
    <div class="package-overlay" @onclick="() => _showPackageGuide = false">
        <div class="package-dialog" @onclick:stopPropagation="true">
            <div class="package-header">
                <strong>Package Your Game</strong>
                <button class="btn btn-sm btn-outline-light" @onclick="() => _showPackageGuide = false">X</button>
            </div>
            <div class="package-tabs">
                <button class="package-tab @(_packageTab == 0 ? "active" : "")" @onclick="() => _packageTab = 0">Web</button>
                <button class="package-tab @(_packageTab == 1 ? "active" : "")" @onclick="() => _packageTab = 1">Desktop (Electron)</button>
                <button class="package-tab @(_packageTab == 2 ? "active" : "")" @onclick="() => _packageTab = 2">Android (APK)</button>
            </div>
            <div class="package-body">
                @if (_packageTab == 0)
                {
                    <h4>Publish as a Web App</h4>
                    <p>Export your game as a static website you can host anywhere (GitHub Pages, Netlify, your own server).</p>
                    @if (_isElectron)
                    {
                        <p>Output: <code>dist/web/</code></p>
                        @BuildButtons("web")
                    }
                    else
                    {
                    <h5>Prerequisites</h5>
                    <ul>
                        <li><a href="https://dot.net" target="_blank">.NET 8 SDK</a> or later</li>
                    </ul>
                    <h5>Steps</h5>
                    <ol>
                        <li>Save your scene (<strong>Save</strong> button) so it persists in the project.</li>
                        <li>Open a terminal in the project root and run:
                            <pre><code>./packaging/build.sh web</code></pre>
                        </li>
                        <li>The output lands in <code>dist/web/</code> — the entire folder is your deployable site.</li>
                        <li>Preview locally:
                            <pre><code>npx serve dist/web</code></pre>
                        </li>
                        <li>Deploy by uploading <code>dist/web/</code> to any static host.</li>
                    </ol>
                    <h5>Options</h5>
                    <ul>
                        <li>Add <code>--aot</code> for ahead-of-time compilation (slower build, faster runtime):
                            <pre><code>./packaging/build.sh web --aot</code></pre>
                            <strong>Note:</strong> AOT requires the <code>wasm-tools</code> workload:
                            <pre><code>dotnet workload install wasm-tools</code></pre>
                        </li>
                    </ul>
                    }
                }
                else if (_packageTab == 1)
                {
                    <h4>Package as a Desktop App</h4>
                    <p>Wrap your game in Electron for a native desktop experience on Windows, macOS, and Linux.</p>
                    @if (_isElectron)
                    {
                        <p>Output: <code>packaging/electron/out/</code></p>
                        @PackageMetadataFields()
                        @BuildButtons("electron")
                    }
                    else
                    {
                    <h5>Prerequisites</h5>
                    <ul>
                        <li><a href="https://dot.net" target="_blank">.NET 8 SDK</a> or later</li>
                        <li><a href="https://nodejs.org" target="_blank">Node.js 18+</a> and npm</li>
                    </ul>
                    <h5>Steps</h5>
                    <ol>
                        <li>Save your scene.</li>
                        <li>Run from the project root:
                            <pre><code>./packaging/build.sh electron</code></pre>
                        </li>
                        <li>This publishes the Blazor app, copies it into the Electron shell, installs dependencies, and builds platform installers.</li>
                        <li>Find your distributable in <code>packaging/electron/out/</code>:
                            <ul>
                                <li><strong>Linux:</strong> AppImage + .deb</li>
                                <li><strong>macOS:</strong> .dmg</li>
                                <li><strong>Windows:</strong> NSIS installer + portable .exe</li>
                            </ul>
                        </li>
                    </ol>
                    <h5>Test before packaging</h5>
                    <pre><code>cd packaging/electron
npm install
npm start</code></pre>
                    <p>This launches Electron in dev mode so you can verify everything works.</p>
                    }
                }
                else
                {
                    <h4>Package as an Android APK</h4>
                    <p>Wrap your game as a native Android app using <a href="https://capacitorjs.com" target="_blank">Capacitor</a>, which embeds the web app in a Chrome-based WebView.</p>
                    @if (_isElectron)
                    {
                        <p>Output: <code>packaging/android/android/app/build/outputs/apk/</code></p>
                        @PackageMetadataFields()
                        @BuildButtons("apk")
                    }
                    else
                    {
                    <h5>Prerequisites</h5>
                    <ul>
                        <li><a href="https://dot.net" target="_blank">.NET 8 SDK</a> or later</li>
                        <li><a href="https://nodejs.org" target="_blank">Node.js 18+</a> and npm</li>
                        <li><a href="https://developer.android.com/studio" target="_blank">Android Studio</a> with SDK installed</li>
                        <li>Set <code>ANDROID_HOME</code> environment variable to your SDK path</li>
                    </ul>
                    <h5>Steps</h5>
                    <ol>
                        <li>Save your scene.</li>
                        <li>Run from the project root:
                            <pre><code>./packaging/build.sh apk</code></pre>
                        </li>
                        <li>On the first run this creates the Android project. Subsequent builds only sync and recompile.</li>
                        <li>The debug APK appears under <code>packaging/android/android/app/build/outputs/apk/debug/</code>.</li>
                        <li>Transfer the <code>.apk</code> file to your device and install it (enable "Install from unknown sources").</li>
                    </ol>
                    <h5>Open in Android Studio</h5>
                    <pre><code>cd packaging/android
npx cap open android</code></pre>
                    <p>This opens the project in Android Studio where you can run on an emulator, configure signing, or build a release APK.</p>
                    <h5>Release build</h5>
                    <pre><code>./packaging/build.sh apk --release</code></pre>
                    <p class="text-muted">Requires signing configuration. See the Android docs on <a href="https://developer.android.com/studio/publish/app-signing" target="_blank">app signing</a>.</p>
                    <h5>Note</h5>
                    <p class="text-muted">WebGPU requires Android 13+ with an up-to-date Chrome-based system WebView. Older devices may not support it.</p>
                    }
                }
            </div>
            @if (_isElectron && !string.IsNullOrEmpty(_buildLog))
            {
                <div class="build-log-container">
                    <div class="build-log-header">
                        <strong>Build Output</strong>
                        <div style="display:flex;gap:6px">
                            <button class="btn btn-sm btn-outline-light" @onclick="CopyBuildLog">@(_buildLogCopied ? "Copied!" : "Copy")</button>
                            <button class="btn btn-sm btn-outline-light" @onclick="() => _buildLog = string.Empty">Clear</button>
                        </div>
                    </div>
                    <pre class="build-log">@_buildLog</pre>
                </div>
            }
        </div>
    </div>
}

