    // --- Save / Load ---

    private async Task TakeScreenshot()
    {
        await JS.InvokeVoidAsync("WgpuSharpEditor.captureScreenshot", "gpu-canvas");
    }

    private async Task SaveScene()
    {
        try
        {
            var gameSettings = new GameSettingsData
            {
                PlayerSpeed = _playerSpeed,
                JumpHeight = _jumpHeight,
                Gravity = _gravity,
                MaxPlayerHealth = _maxPlayerHealth,
                TimerEnabled = _timerEnabled,
                TimerMax = _levelTimerMax,
                WinCondition = _winCondition,
                StartMessage = _startMessage,
            };
            var json = SceneSerializer.Serialize(_scene, _settings, gameSettings);
            await JS.InvokeVoidAsync("WgpuSharpEditor.downloadFile", "scene.json", json);
        }
        catch (Exception ex)
        {
            _error = $"Save failed: {ex.Message}";
        }
    }

    private async Task LoadScene()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("WgpuSharpEditor.pickAndReadFile", ".json");
            if (string.IsNullOrWhiteSpace(json)) return;

            var data = SceneSerializer.Deserialize(json);
            SceneSerializer.Rebuild(_scene, data, ResolveMeshFull);
            _nodeCounter = _scene.GetAllNodes().Count();

            // Reconstruct skinned nodes (async GPU setup)
            foreach (var node in _scene.GetAllNodes())
            {
                if (node.MeshType == "ImportedSkinned" && node.ImportedMeshData is not null)
                    await SetupSkinnedNodeFromGlb(node, node.ImportedMeshData);
            }
        }
        catch (Exception ex)
        {
            _error = $"Load failed: {ex.Message}";
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_loop is not null) await _loop.DisposeAsync();
        if (_renderer is not null) await _renderer.DisposeAsync();
        if (_input is not null) await _input.DisposeAsync();
    }

