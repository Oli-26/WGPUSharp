    {
        if (_flyMode) return;
        _freeLookCamera.InitFromFpsCamera(_fpsCamera);
        _flyMode = true;
    }

    private string GetObjectiveText() => _winCondition switch
    {
        "collect_all" => $"Collect all items ({_score}/{_totalCollectibles})",
        "reach_goal" => "Reach the goal",
        "timer" => $"Survive for {TimeSpan.FromSeconds(Math.Max(0, _levelTimerMax - _playTime)):m\\:ss}",
        _ => "",
    };

    private void UpdateCollectibles(float dt)
    {
        var playerPos = _fpsCamera.Position - new Vector3(0, FpsCamera.EyeHeight, 0);
        float pw = 0.5f; // collection radius

        foreach (var node in _scene.AllNodesCached)
        {
            if (node.Tag != NodeTag.Collectible || !node.Visible) continue;
            if (_collectedIds.Contains(node.Id)) continue;

            // Rotate collectibles (bobbing spin)
            var euler = node.Transform.EulerAngles;
            euler.Y += 2f * dt;
            node.Transform.EulerAngles = euler;
            // Gentle bob
            var basePos = _playModeSnapshot.TryGetValue(node.Id, out var snap) ? snap.pos : node.Transform.Position;
            node.Transform.Position = basePos + new Vector3(0, MathF.Sin(_playTime * 3f) * 0.15f, 0);

            // Check player proximity
            var objPos = node.Transform.WorldMatrix.Translation;
            var diff = playerPos - objPos;
            diff.Y *= 0.5f; // forgiving vertical range
            if (diff.Length() < pw + 0.5f)
            {
                // Collected!
                node.Visible = false;
                _collectedIds.Add(node.Id);
                _score++;
            }
        }
    }

    private void CheckTriggers(float dt)
    {
        if (_triggerMessageTimer > 0)
        {
            _triggerMessageTimer -= dt;
            if (_triggerMessageTimer <= 0) _triggerMessage = null;
        }

        var playerPos = _fpsCamera.Position - new Vector3(0, FpsCamera.EyeHeight, 0);
        foreach (var node in _scene.AllNodesCached)
        {
            if (node.Tag != NodeTag.Trigger || !node.Visible) continue;
            var aabb = FpsCamera.ComputeWorldAABB(node.Transform.WorldMatrix);
            bool inside = playerPos.X > aabb.Min.X && playerPos.X < aabb.Max.X
                       && playerPos.Y > aabb.Min.Y && playerPos.Y < aabb.Max.Y + 1.8f
                       && playerPos.Z > aabb.Min.Z && playerPos.Z < aabb.Max.Z;
            if (inside && !_activeTriggers.Contains(node.Id))
            {
                _activeTriggers.Add(node.Id);
                _triggerMessage = $"Entered: {node.Name}";
                _triggerMessageTimer = 3f;
            }
            else if (!inside)
            {
                _activeTriggers.Remove(node.Id);
            }
        }
    }

    private void UpdateEnemies(float dt)
    {
        if (_playerHealth <= 0) return;
        _damageCooldown = MathF.Max(0, _damageCooldown - dt);

        var playerFeet = _fpsCamera.Position - new Vector3(0, FpsCamera.EyeHeight, 0);
        foreach (var node in _scene.AllNodesCached)
        {
            if (node.Tag != NodeTag.Enemy || !node.Visible) continue;
            var pos = node.Transform.Position;
            var toPlayer = playerFeet - pos;
            toPlayer.Y = 0;
            float dist = toPlayer.Length();

            if (dist > 0.5f && dist < 12f)
            {
                var dir = toPlayer / dist;
                node.Transform.Position = pos + dir * MathF.Min(2.5f * dt, dist - 0.4f);
            }

            if (dist < 1.2f && _damageCooldown <= 0)
            {
                _playerHealth = Math.Max(0, _playerHealth - 10);
                _damageCooldown = 1f;
            }
        }
    }

    private void UpdateDoorsAndKeys(float dt)
    {
        var playerPos = _fpsCamera.Position - new Vector3(0, FpsCamera.EyeHeight, 0);

        // Collect keys
        foreach (var node in _scene.AllNodesCached)
        {
            if (node.Tag != NodeTag.Key || !node.Visible) continue;
            var pos = node.Transform.WorldMatrix.Translation;
            if (Vector3.Distance(playerPos, pos) < 1.5f)
            {
                node.Visible = false;
                // Key name prefix is the key ID (e.g. "Red Key" matches "Red Door")
                var prefix = node.Name.Replace(" Key", "").Replace(" key", "").Trim();
                _collectedKeys.Add(prefix);
                _triggerMessage = $"Picked up: {node.Name}";
                _triggerMessageTimer = 2f;
            }
        }

        // Open matching doors
        foreach (var node in _scene.AllNodesCached)
        {
            if (node.Tag != NodeTag.Door) continue;
            var prefix = node.Name.Replace(" Door", "").Replace(" door", "").Trim();
            if (_collectedKeys.Contains(prefix))
            {
                node.Solid = false;
                node.Visible = false; // door disappears when unlocked
            }
        }
    }

    private void UpdateTeleporters()
    {
        if (_teleportCooldown > 0) { _teleportCooldown -= 0.016f; return; }
        var playerPos = _fpsCamera.Position - new Vector3(0, FpsCamera.EyeHeight, 0);
        foreach (var node in _scene.AllNodesCached)
        {
            if (node.Tag != NodeTag.Teleporter || !node.Visible) continue;
            var pos = node.Transform.WorldMatrix.Translation;
            if (Vector3.Distance(playerPos, pos) > 1.5f) continue;
            // Find matching teleporter by name prefix
            var prefix = node.Name.Split(' ')[0];
            foreach (var other in _scene.AllNodesCached)
            {
                if (other.Tag != NodeTag.Teleporter || other.Id == node.Id || !other.Visible) continue;
                if (!other.Name.StartsWith(prefix)) continue;
                var dest = other.Transform.WorldMatrix.Translation;
                _fpsCamera.Position = dest + new Vector3(0, FpsCamera.EyeHeight, 0);
                _teleportCooldown = 1f;
                _triggerMessage = $"Teleported to {other.Name}";
                _triggerMessageTimer = 2f;
                return;
            }
        }
    }

    private readonly List<object> _minimapDots = new(64);
    private async Task DrawMinimap()
    {
        var playerPos = _fpsCamera.Position;
        _minimapDots.Clear();
        _minimapDots.Add(new { x = playerPos.X, z = playerPos.Z, color = "#0f0", size = 4 });
        foreach (var node in _scene.AllNodesCached)
        {
            if (!node.Visible) continue;
            var p = node.Transform.WorldMatrix.Translation;
            if (node.Tag == NodeTag.Enemy) _minimapDots.Add(new { x = p.X, z = p.Z, color = "#f44", size = 3 });
            else if (node.Tag == NodeTag.Collectible) _minimapDots.Add(new { x = p.X, z = p.Z, color = "#ff0", size = 2 });
            else if (node.Tag == NodeTag.Key) _minimapDots.Add(new { x = p.X, z = p.Z, color = "#0ff", size = 2 });
        }
        await JS.InvokeVoidAsync("WgpuSharpEditor.drawMinimap", playerPos.X, playerPos.Z, _minimapDots);
    }

    private void CheckCheckpoints()
    {
        var playerPos = _fpsCamera.Position - new Vector3(0, FpsCamera.EyeHeight, 0);
        foreach (var node in _scene.AllNodesCached)
        {
            if (node.Tag != NodeTag.Checkpoint || !node.Visible) continue;
            var aabb = FpsCamera.ComputeWorldAABB(node.Transform.WorldMatrix);
            bool inside = playerPos.X > aabb.Min.X && playerPos.X < aabb.Max.X
                       && playerPos.Y > aabb.Min.Y && playerPos.Y < aabb.Max.Y + 1.8f
                       && playerPos.Z > aabb.Min.Z && playerPos.Z < aabb.Max.Z;
            if (inside)
            {
                var cp = node.Transform.WorldMatrix.Translation;
                if (Vector3.Distance(cp, _lastCheckpoint) > 0.5f)
                {
                    _lastCheckpoint = cp;
                    _triggerMessage = $"Checkpoint: {node.Name}";
                    _triggerMessageTimer = 2f;
                }
            }
        }
    }

    private void UpdateNPCs()
    {
        var playerPos = _fpsCamera.Position - new Vector3(0, FpsCamera.EyeHeight, 0);
        foreach (var node in _scene.AllNodesCached)
        {
            if (node.Tag != NodeTag.NPC || !node.Visible) continue;
            var pos = node.Transform.WorldMatrix.Translation;
            if (Vector3.Distance(playerPos, pos) < 3f)
            {
                _triggerMessage = node.Name;
                _triggerMessageTimer = 0.5f;
                return;
            }
        }
    }

    private void UpdateDamageZones(float dt)
    {
        _damageZoneCooldown = MathF.Max(0, _damageZoneCooldown - dt);
        if (_damageZoneCooldown > 0 || _playerHealth <= 0) return;
        var playerPos = _fpsCamera.Position - new Vector3(0, FpsCamera.EyeHeight, 0);
        foreach (var node in _scene.AllNodesCached)
        {
            if (node.Tag != NodeTag.DamageZone || !node.Visible) continue;
            var aabb = FpsCamera.ComputeWorldAABB(node.Transform.WorldMatrix);
            bool inside = playerPos.X > aabb.Min.X && playerPos.X < aabb.Max.X
                       && playerPos.Y > aabb.Min.Y && playerPos.Y < aabb.Max.Y + 1.8f
                       && playerPos.Z > aabb.Min.Z && playerPos.Z < aabb.Max.Z;
            if (inside) { _playerHealth = Math.Max(0, _playerHealth - 5); _damageZoneCooldown = 0.3f; return; }
        }
    }

    private void UpdateHealthPickups()
    {
        if (_playerHealth >= _maxPlayerHealth) return;
        var playerPos = _fpsCamera.Position - new Vector3(0, FpsCamera.EyeHeight, 0);
        foreach (var node in _scene.AllNodesCached)
        {
            if (node.Tag != NodeTag.HealthPickup || !node.Visible) continue;
            if (_collectedIds.Contains(node.Id)) continue;
            var pos = node.Transform.WorldMatrix.Translation;
            if (Vector3.Distance(playerPos, pos) < 1.5f)
            {
                _playerHealth = Math.Min(_maxPlayerHealth, _playerHealth + 25);
                node.Visible = false;
                _collectedIds.Add(node.Id);
                _triggerMessage = "+25 HP";
                _triggerMessageTimer = 1.5f;
            }
        }
    }

    private void ExecuteScripts(float dt)
    {
        var playerPos = _fpsCamera.Position - new Vector3(0, FpsCamera.EyeHeight, 0);
        foreach (var (id, data) in _scriptData)
        {
            var node = _scene.FindById(id);
            if (node is null || !node.Visible) continue;
            ScriptEngine.Execute(node, data.cmds, data.state, data.startPos, dt, _playTime, playerPos, _scene,
                (msg, dur) => { _triggerMessage = msg; _triggerMessageTimer = dur; });
        }
    }

    private void UpdateMovingPlatforms(float dt)
    {
        foreach (var node in _scene.AllNodesCached)
        {
            if (node.Tag != NodeTag.MovingPlatform || !node.Visible) continue;
            if (!_playModeSnapshot.TryGetValue(node.Id, out var snap)) continue;
            var startPos = snap.pos;
            var endPos = node.MoveTarget;
            if (Vector3.DistanceSquared(startPos, endPos) < 0.01f) continue;
            float t = (MathF.Sin(_playTime * 1.5f) + 1f) * 0.5f;
            node.Transform.Position = Vector3.Lerp(startPos, endPos, t);
        }
    }

    // --- Grid snap ---

    private Vector3 SnapPosition(Vector3 pos)
    {
        if (!_snapEnabled || _snapSize <= 0) return pos;
        return new Vector3(
            MathF.Round(pos.X / _snapSize) * _snapSize,
            MathF.Round(pos.Y / _snapSize) * _snapSize,
            MathF.Round(pos.Z / _snapSize) * _snapSize);
    }

    private float SnapValue(float val)
    {
        if (!_snapEnabled || _snapSize <= 0) return val;
        return MathF.Round(val / _snapSize) * _snapSize;
    }

    private string _selectedTemplate = "Platformer";
    private static readonly string[] SceneTemplates = ["Empty", "Sandbox", "Platformer", "Arena", "Puzzle Room", "Race Track", "Obstacle Course"];

    private void LoadTemplate(string template)
    {
        // Clear scene
        while (_scene.Roots.Count > 0) _scene.Remove(_scene.Roots[0]);
        ClearSelection();
        _undo.Clear();
        _nodeCounter = 0;

        switch (template)
        {
            case "Sandbox": SetupSandbox(); break;
            case "Platformer": SetupPlatformer(); break;
            case "Arena": SetupArena(); break;
            case "Puzzle Room": SetupPuzzleRoom(); break;
            case "Race Track": SetupRaceTrack(); break;
            case "Obstacle Course": SetupObstacleCourse(); break;
            // "Empty" — just a light
        }

        // Every template gets a light
        AddLightNode(new Vector3(0, 5f, 0), new Vector3(1f, 0.95f, 0.85f), 4f, 20f);
    }

    private Task SetupDefaultScene() { LoadTemplate(_selectedTemplate); return Task.CompletedTask; }

