    private void ApplyScriptTemplate(SceneNode node, ChangeEventArgs e)
    {
        var name = e.Value?.ToString();
        if (string.IsNullOrEmpty(name)) return;
        var template = Array.Find(ScriptTemplates, t => t.name == name);
        if (template == default) return;
        // Append to existing script (or set if empty)
        if (string.IsNullOrWhiteSpace(node.Script))
            node.Script = template.script;
        else
            node.Script = node.Script.TrimEnd() + "\n\n" + template.script;
    }

