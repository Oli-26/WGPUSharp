    // --- Selection helpers ---

    private bool IsSelected(int nodeId) => _selectedIds.Contains(nodeId);

    private void SelectSingle(SceneNode? node)
    {
        _selectedIds.Clear();
        if (node is not null) _selectedIds.Add(node.Id);
        _scene.SelectedNode = node;
    }

    private void ToggleSelect(SceneNode node)
    {
        if (_selectedIds.Contains(node.Id))
        {
            _selectedIds.Remove(node.Id);
            _scene.SelectedNode = _selectedIds.Count > 0 ? _scene.FindById(_selectedIds.First()) : null;
        }
        else
        {
            _selectedIds.Add(node.Id);
            _scene.SelectedNode = node;
        }
    }

    private void SelectAll()
    {
        _selectedIds.Clear();
        SceneNode? last = null;
        foreach (var node in _scene.GetAllNodes())
        {
            _selectedIds.Add(node.Id);
            last = node;
        }
        _scene.SelectedNode = last;
    }

    private void ClearSelection()
    {
        _selectedIds.Clear();
        _scene.SelectedNode = null;
    }

    private readonly List<SceneNode> _selectedNodesCache = new();
    private List<SceneNode> GetSelectedNodes()
    {
        _selectedNodesCache.Clear();
        foreach (var id in _selectedIds)
        {
            var node = _scene.FindById(id);
            if (node is not null) _selectedNodesCache.Add(node);
        }
        return _selectedNodesCache;
    }

    private void ReparentNode(SceneNode newParent)
    {
        if (_dragNodeId is null) return;
        var dragNode = _scene.FindById(_dragNodeId.Value);
        if (dragNode is null || dragNode == newParent) return;
        if (newParent.FindById(dragNode.Id) is not null) return;
        dragNode.Detach();
        _scene.Remove(dragNode);
        newParent.AddChild(dragNode);
        _dragNodeId = null;
    }

    private void ReparentToRoot()
    {
        if (_dragNodeId is null) return;
        var dragNode = _scene.FindById(_dragNodeId.Value);
        if (dragNode is null) return;
        dragNode.Detach();
        _scene.Remove(dragNode);
        _scene.Add(dragNode);
        _dragNodeId = null;
    }

