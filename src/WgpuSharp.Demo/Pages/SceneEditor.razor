    // --- Mesh import ---

    // --- Mesh import ---

    private string? _importPhase;
    private int _importPercent;
    private bool _importing;

    private async Task ImportMesh()
    {
        if (_device is null) return;
        try
        {
            _importing = true;
            _importPhase = "Picking file...";
            _importPercent = 0;
            StateHasChanged();

            // Pick file and read as base64 (runs in Web Worker — off main thread)
            var result = await JS.InvokeAsync<string?>("WgpuSharpEditor.pickAndReadFileBase64", ".obj,.glb,.stl");
            if (result is null) { _importing = false; return; }

            // Result format: "filename|base64data"
            var sep = result.IndexOf('|');
            if (sep < 0) { _importing = false; return; }
            var fileName = result[..sep];
            var base64 = result[(sep + 1)..];

            _importPhase = "Decoding...";
            _importPercent = 30;
            StateHasChanged();
            await Task.Yield(); // let UI update

            var bytes = Convert.FromBase64String(base64);

            _importPhase = "Parsing mesh...";
            _importPercent = 50;
            StateHasChanged();
            await Task.Yield();

            // Try skinned loading for GLB files
            if (fileName.EndsWith(".glb", StringComparison.OrdinalIgnoreCase))
            {
                var glbResult = GlbLoader.LoadWithSkin(bytes);
                if (glbResult.HasSkin && glbResult.SkinnedMeshes.Length > 0)
                {
                    await ImportSkinnedMesh(glbResult, bytes, fileName);
                    _importPercent = 100;
                    _importPhase = null;
                    return;
                }
            }

            var meshes = MeshLoader.Load(bytes, fileName);
            if (meshes.Length == 0) { _importing = false; _error = "No meshes found in file."; return; }

            var mesh = meshes[0];

            if (!mesh.HasNormals)
            {
                _importPhase = "Computing normals...";
                _importPercent = 70;
                StateHasChanged();
                await Task.Yield();

                mesh = mesh.ComputeFlatNormals();
            }

            _importPhase = "Uploading to GPU...";
            _importPercent = 85;
            StateHasChanged();
            await Task.Yield();

            var buffers = await mesh.CreateBuffersAsync(_device);

            // Generate LOD meshes automatically
            _importPhase = "Generating LODs...";
            _importPercent = 90;
            StateHasChanged();
            await Task.Yield();

            MeshBuffers?[]? lodMeshes = null;
            if (mesh.VertexCount > 100) // Only generate LODs for non-trivial meshes
            {
                var lods = MeshSimplifier.GenerateLODs(mesh);
                var lod0 = lods[0] != mesh ? await lods[0].CreateBuffersAsync(_device) : null;
                var lod1 = lods[1] != mesh ? await lods[1].CreateBuffersAsync(_device) : null;
                if (lod0 is not null || lod1 is not null)
                    lodMeshes = [lod0, lod1];
            }

            var name = Path.GetFileNameWithoutExtension(fileName);
            var node = new SceneNode($"{name} {++_nodeCounter}")
            {
                MeshBuffers = buffers,
                MeshType = "Imported",
                ImportedMeshData = bytes,
                ImportedMeshFileName = fileName,
                Color = new Vector4(0.8f, 0.8f, 0.8f, 1f),
                LodMeshes = lodMeshes,
            };
            node.Transform.Position = SnapPosition(new Vector3(0, 0.5f, 0));
            _undo.Do(new AddNodeAction(_scene, node));
            SelectSingle(node);

            _importPercent = 100;
            _importPhase = null;
        }
        catch (Exception ex)
        {
            _error = $"Import failed: {ex.Message}";
        }
        finally
        {
            _importing = false;
            StateHasChanged();
        }
    }

    private async Task ImportSkinnedMesh(GlbResult glbResult, byte[] rawBytes, string fileName)
    {
        var skinnedMesh = glbResult.SkinnedMeshes[0];
        var skeleton = glbResult.Skeleton!;

        _importPhase = "Uploading skinned mesh...";
        _importPercent = 70;
        StateHasChanged();
        await Task.Yield();

        var skinnedBuffers = await skinnedMesh.CreateBuffersAsync(_device!);

        _importPhase = "Creating skeleton buffers...";
        _importPercent = 85;
        StateHasChanged();
        await Task.Yield();

        var jointBufferSize = Math.Max(256, skeleton.JointCount * 64);
        var jointBuffer = await _device!.CreateBufferAsync(new BufferDescriptor
        {
            Size = jointBufferSize,
            Usage = BufferUsage.Storage | BufferUsage.CopyDest,
        });

        var jointBindGroup = await _device.CreateBindGroupAsync(
            _renderer!.SkinnedPipeline, 1,
            [new BindGroupEntry { Binding = 0, Buffer = jointBuffer, Size = jointBufferSize }]);

        var animPlayer = new AnimationPlayer(skeleton, glbResult.Animations);
        animPlayer.Play();

        _importPhase = "Finalizing...";
        _importPercent = 95;
        StateHasChanged();
        await Task.Yield();

        var name = Path.GetFileNameWithoutExtension(fileName);
        var node = new SceneNode($"{name} {++_nodeCounter}")
        {
            MeshType = "ImportedSkinned",
            ImportedMeshData = rawBytes,
            ImportedMeshFileName = fileName,
            Color = new Vector4(0.8f, 0.8f, 0.8f, 1f),
            AnimationPlayer = animPlayer,
            SkinnedRenderData = new SkinnedRenderData
            {
                Buffers = skinnedBuffers,
                JointBuffer = jointBuffer,
                JointBindGroup = jointBindGroup,
            },
        };
        node.Transform.Position = SnapPosition(new Vector3(0, 0.5f, 0));
        _undo.Do(new AddNodeAction(_scene, node));
        SelectSingle(node);
    }

    private async Task<MeshBuffers?> CreateImportedMeshBuffers(byte[] data, string fileName)
    {
        if (_device is null) return null;
        var meshes = MeshLoader.Load(data, fileName);
        if (meshes.Length == 0) return null;
        var mesh = meshes[0];
        if (!mesh.HasNormals) mesh = mesh.ComputeFlatNormals();
        return await mesh.CreateBuffersAsync(_device);
    }

    private async Task SetupSkinnedNodeFromGlb(SceneNode node, byte[] data)
    {
        if (_device is null) return;
        var glbResult = GlbLoader.LoadWithSkin(data);
        if (!glbResult.HasSkin || glbResult.SkinnedMeshes.Length == 0) return;

        var skinnedBuffers = await glbResult.SkinnedMeshes[0].CreateBuffersAsync(_device);
        var skeleton = glbResult.Skeleton!;
        var jointBufferSize = Math.Max(256, skeleton.JointCount * 64);
        var jointBuffer = await _device.CreateBufferAsync(new BufferDescriptor
        {
            Size = jointBufferSize,
            Usage = BufferUsage.Storage | BufferUsage.CopyDest,
        });
        var jointBindGroup = await _device.CreateBindGroupAsync(
            _renderer!.SkinnedPipeline, 1,
            [new BindGroupEntry { Binding = 0, Buffer = jointBuffer, Size = jointBufferSize }]);

        node.AnimationPlayer = new AnimationPlayer(skeleton, glbResult.Animations);
        node.AnimationPlayer.Play();
        node.SkinnedRenderData = new SkinnedRenderData
        {
            Buffers = skinnedBuffers,
            JointBuffer = jointBuffer,
            JointBindGroup = jointBindGroup,
        };
    }

    // --- Play mode ---

    // Store original transforms so we can restore on exit
    private Dictionary<int, (Vector3 pos, Quaternion rot, bool visible, bool solid)> _playModeSnapshot = new();

    private void EnterPlayMode()
    {
        _fpsCamera.InitFromOrbitCamera(_camera);
        _freeLookCamera.InitFromOrbitCamera(_camera);
        _flyMode = false;
        _score = 0;
        _playTime = 0;
        _collectedIds.Clear();
        _activeTriggers.Clear();
        _collectedKeys.Clear();
        _triggerMessage = null;
        _triggerMessageTimer = 0;
        _playerHealth = _maxPlayerHealth;
        _damageCooldown = 0;
        _damageZoneCooldown = 0;
        _teleportCooldown = 0;
        _lastCheckpoint = Vector3.Zero;
        _levelTimer = _levelTimerMax;
        _totalCollectibles = _scene.GetAllNodes().Count(n => n.Tag == NodeTag.Collectible);
        _hasEnemies = _scene.GetAllNodes().Any(n => n.Tag == NodeTag.Enemy);

        // Apply game settings to FPS camera
        _fpsCamera.MoveSpeed = _playerSpeed;
        _fpsCamera.JumpVelocity = _jumpHeight;
        _fpsCamera.GravityStrength = _gravity;

        // HUD timers
        _startMessageTimer = string.IsNullOrEmpty(_startMessage) ? 0 : 3f;
        _speedIndicatorTimer = 0;

        // Snapshot transforms so we can restore after play
        _playModeSnapshot.Clear();
        _scriptData.Clear();
        foreach (var node in _scene.GetAllNodes())
        {
            _playModeSnapshot[node.Id] = (node.Transform.Position, node.Transform.Rotation, node.Visible, node.Solid);
            // Parse scripts
            if (!string.IsNullOrWhiteSpace(node.Script))
            {
                var cmds = ScriptEngine.Parse(node.Script);
                if (cmds.Count > 0)
                    _scriptData[node.Id] = (cmds, new ScriptState(), node.Transform.Position);
            }
        }

        _playMode = true;
    }

    private void ExitPlayMode()
    {
        _playMode = false;
        _paused = false;

        // Restore transforms, visibility, and solidity from snapshot
        foreach (var (id, snap) in _playModeSnapshot)
        {
            var node = _scene.FindById(id);
            if (node is null) continue;
            node.Transform.Position = snap.pos;
            node.Transform.Rotation = snap.rot;
            node.Visible = snap.visible;
            node.Solid = snap.solid;
        }

        // Clear all play-mode state
        _scriptData.Clear();
        _triggerMessage = null;
        _triggerMessageTimer = 0;
        _collectedIds.Clear();
        _collectedKeys.Clear();
        _activeTriggers.Clear();

        _ = JS.InvokeVoidAsync("WgpuSharpEditor.stopAllAudio");
    }

    private void SwitchToFps()
    {
        if (!_flyMode) return;
        _fpsCamera.Position = _freeLookCamera.Position;
        _fpsCamera.Yaw = _freeLookCamera.Yaw;
        _fpsCamera.Pitch = _freeLookCamera.Pitch;
        _flyMode = false;
    }

