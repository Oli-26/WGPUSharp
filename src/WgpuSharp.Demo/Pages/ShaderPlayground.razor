    wave += sin(p.x * 6.0 + t * 1.2) * 0.02;
    wave += sin(p.x * 13.0 - t * 0.8 + 1.0) * 0.01;
    wave += sin(p.x * 26.0 + t * 2.1 + 2.0) * 0.005;

