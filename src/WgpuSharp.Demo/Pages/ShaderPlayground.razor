        new("Spiral Galaxy", @"
fn hash(p: vec2f) -> f32 {
    return fract(sin(dot(p, vec2f(12.9898, 78.233))) * 43758.5453);
}

@fragment
fn fs_main(@location(0) uv: vec2f) -> @location(0) vec4f {
    let t = globals.time * 0.15;
    let p = (uv - 0.5) * 2.5;
    let r = length(p);
    let a = atan2(p.y, p.x);

    // Logarithmic spiral arms
    var arms = 0.0;
    for (var i = 0; i < 3; i++) {
        let arm_offset = f32(i) * 6.28 / 3.0;
        let spiral = a - log(r + 0.01) * 2.5 + arm_offset + t;
        let arm = exp(-pow(sin(spiral) * r * 3.0, 2.0)) * exp(-r * 1.5);
        arms += arm;
    }

    // Core glow
    let core = 0.03 / (r * r + 0.01);

    // Stars
    let star_field = hash(floor(uv * 300.0));
    let star = step(0.997, star_field) * (sin(t * 20.0 + star_field * 100.0) * 0.3 + 0.7);

    // Dust lanes (dark regions)
    let dust = smoothstep(0.3, 0.6, arms) * 0.3;

    let arm_color = mix(vec3f(0.3, 0.4, 1.0), vec3f(1.0, 0.6, 0.8), r * 0.8);
    let core_color = vec3f(1.0, 0.95, 0.8);

    var color = arm_color * arms * 0.8 + core_color * core * 0.15 + star * 0.4;
    color *= (1.0 - dust);
    return vec4f(color, 1.0);
}
