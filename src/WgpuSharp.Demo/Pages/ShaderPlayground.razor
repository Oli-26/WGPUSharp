@page "/shader-playground"
@using WgpuSharp.Core
@using WgpuSharp.Commands
@using WgpuSharp.Pipeline
@using WgpuSharp.Resources
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>WgpuSharp — Shader Playground</PageTitle>

<h3>Shader Playground</h3>
<p>Write WGSL fragment shaders with live preview. Drag or click snippets to insert.</p>

<details style="margin-bottom: 12px; background: #151520; border: 1px solid #333; border-radius: 6px; padding: 0;">
    <summary style="padding: 10px 14px; cursor: pointer; color: #aaa; font-weight: bold; user-select: none;">
        How to Write Shaders — Quick Guide
    </summary>
    <div style="padding: 12px 16px; font-size: 0.88em; color: #bbb; line-height: 1.6;">
        <h5 style="color: #e0e0e0; margin-top: 0;">Basics</h5>
        <p>You write a <strong>fragment shader</strong> — a function that runs for every pixel and returns a color.
        You receive <code>uv</code> (pixel position from 0 to 1) and return <code>vec4f(r, g, b, a)</code>.</p>
<pre style="background: #1e1e2e; padding: 8px; border-radius: 4px; overflow-x: auto; color: #cdd6f4;">@@fragment
fn fs_main(@@location(0) uv: vec2f) -> @@location(0) vec4f {
    return vec4f(uv.x, uv.y, 0.5, 1.0);  // red=x, green=y, blue=0.5
}</pre>

        <h5 style="color: #e0e0e0;">Available Uniforms</h5>
        <table style="width: 100%; border-collapse: collapse; margin-bottom: 8px;">
            <tr style="border-bottom: 1px solid #333;">
                <td style="padding: 4px 8px;"><code>globals.time</code></td>
                <td style="padding: 4px 8px;">Elapsed seconds (f32) — use for animation</td>
            </tr>
            <tr style="border-bottom: 1px solid #333;">
                <td style="padding: 4px 8px;"><code>globals.resolution</code></td>
                <td style="padding: 4px 8px;">Canvas size in pixels (vec2f)</td>
            </tr>
            <tr>
                <td style="padding: 4px 8px;"><code>globals.mouse</code></td>
                <td style="padding: 4px 8px;">Mouse position 0-1 (vec2f) — move over the canvas</td>
            </tr>
        </table>

        <h5 style="color: #e0e0e0;">Key WGSL Types</h5>
        <ul style="margin: 0; padding-left: 20px;">
            <li><code>f32</code> — float, <code>vec2f</code> — 2D vector, <code>vec3f</code> — 3D/color, <code>vec4f</code> — color+alpha</li>
            <li>Construct: <code>vec3f(1.0, 0.0, 0.0)</code> = red, <code>vec3f(0.5)</code> = grey</li>
            <li>Swizzle: <code>color.rgb</code>, <code>uv.yx</code>, <code>v.xxx</code></li>
        </ul>

        <h5 style="color: #e0e0e0;">Useful Functions</h5>
        <ul style="margin: 0; padding-left: 20px;">
            <li><code>sin(x)</code>, <code>cos(x)</code> — oscillation, waves</li>
            <li><code>length(p)</code> — distance from origin (circles!)</li>
            <li><code>fract(x)</code> — fractional part (tiling, patterns)</li>
            <li><code>smoothstep(edge0, edge1, x)</code> — smooth threshold (anti-aliased shapes)</li>
            <li><code>mix(a, b, t)</code> — linear interpolation (gradients, blending)</li>
            <li><code>step(edge, x)</code> — hard threshold (0 or 1)</li>
            <li><code>clamp(x, lo, hi)</code> — constrain value</li>
            <li><code>atan2(y, x)</code> — angle (polar coordinates, spirals)</li>
            <li><code>abs(x)</code>, <code>floor(x)</code>, <code>fract(x)</code> — for patterns and grids</li>
        </ul>

        <h5 style="color: #e0e0e0;">Common Patterns</h5>
        <ul style="margin: 0; padding-left: 20px;">
            <li><strong>Circle:</strong> <code>length(uv - 0.5)</code> gives distance from center. Threshold with <code>smoothstep</code>.</li>
            <li><strong>Animation:</strong> Add <code>globals.time</code> to angles or positions.</li>
            <li><strong>Tiling:</strong> <code>fract(uv * N)</code> repeats the UV space N times.</li>
            <li><strong>Noise:</strong> Use <code>fract(sin(dot(...)) * 43758.5453)</code> as a cheap hash.</li>
            <li><strong>Colors:</strong> Build from HSV using the hue snippet, or <code>mix()</code> two colors.</li>
            <li><strong>SDF (Signed Distance Fields):</strong> Describe shapes as distance functions. Combine with <code>min()</code> (union), <code>max()</code> (intersection), <code>-d</code> (invert).</li>
            <li><strong>Glow:</strong> <code>0.01 / distance</code> creates a glow/light effect.</li>
        </ul>

        <h5 style="color: #e0e0e0;">Tips</h5>
        <ul style="margin: 0; padding-left: 20px;">
            <li>Start simple — get a circle on screen, then animate it, then add color.</li>
            <li>Use the snippet buttons to insert common patterns at your cursor.</li>
            <li>WGSL uses <code>let</code> for constants and <code>var</code> for mutable variables.</li>
            <li>Helper functions go <em>above</em> <code>@@fragment fn fs_main</code>.</li>
            <li>Save your work with the Save button — shaders persist in your browser.</li>
        </ul>
    </div>
</details>

<div class="snippet-palette" style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px;">
    @foreach (var snippet in Snippets)
    {
        <div class="snippet-btn"
             draggable="true"
             @ondragstart="() => {}"
             @ondragstart:preventDefault="false"
             title="@snippet.Description"
             style="padding: 4px 10px; background: #2a2a3a; border: 1px solid #555; border-radius: 4px; cursor: grab; font-size: 0.82em; color: #ccc; user-select: none;"
             @onclick="() => InsertSnippet(snippet.Code)"
             data-snippet="@snippet.Code">
            @snippet.Label
        </div>
    }
</div>

<div style="display: flex; gap: 12px; height: 520px;">
    <div style="flex: 1; display: flex; flex-direction: column;">
        <div style="display: flex; gap: 8px; margin-bottom: 6px; align-items: center;">
            <button class="btn btn-sm btn-primary" @onclick="CompileAndReload" disabled="@(!_gpuReady)">
                Compile & Reload
            </button>
            <label style="font-size: 0.85em; color: #aaa;">
                <input type="checkbox" @bind="_autoReload" /> Auto-reload on edit
            </label>
            @if (_fps > 0)
            {
                <span style="font-size: 12px; color: #888; margin-left: auto;">@_fps.ToString("F0") FPS</span>
            }
        </div>

        <textarea id="shader-editor"
                  @bind="_shaderCode"
                  @bind:event="oninput"
                  @bind:after="OnShaderChanged"
                  spellcheck="false"
                  style="flex: 1; font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace; font-size: 13px; background: #1e1e2e; color: #cdd6f4; border: 1px solid #555; padding: 10px; resize: none; tab-size: 4; white-space: pre; overflow: auto; border-radius: 4px;"></textarea>

        @if (_compileError is not null)
        {
            <div style="background: #3b1111; border: 1px solid #ff4444; color: #ff8888; padding: 10px; margin-top: 6px; font-family: monospace; font-size: 12px; border-radius: 4px; max-height: 120px; overflow: auto; white-space: pre-wrap;">
                <strong style="color: #ff4444;">Shader Error:</strong>
                @_compileError
            </div>
        }
        else if (_compiled)
        {
            <div style="background: #113b11; border: 1px solid #44ff44; color: #88ff88; padding: 6px 10px; margin-top: 6px; font-size: 12px; border-radius: 4px;">
                Compiled successfully
            </div>
        }
    </div>
    <div style="flex: 0 0 512px;">
        <canvas id="shader-canvas" width="512" height="512"
                style="border: 1px solid #555; display: block; border-radius: 4px; cursor: crosshair;"
                @onmousemove="OnMouseMove"></canvas>
    </div>
</div>

<div style="display: flex; gap: 24px; margin-top: 12px; flex-wrap: wrap; align-items: flex-start;">
    <div>
        <strong>Templates:</strong><br/>
        @foreach (var tmpl in Templates)
        {
            <button class="btn btn-sm btn-outline-secondary" style="margin: 2px 4px 2px 0;"
                    @onclick="() => LoadTemplate(tmpl)">@tmpl.Name</button>
        }
    </div>
    <div style="border-left: 1px solid #444; padding-left: 16px;">
        <strong>Save / Load:</strong>
        <div style="display: flex; gap: 6px; margin-top: 4px; align-items: center;">
            <input type="text" @bind="_saveName" placeholder="Shader name..."
                   style="background: #1e1e2e; color: #cdd6f4; border: 1px solid #555; padding: 3px 8px; border-radius: 4px; width: 160px; font-size: 0.85em;" />
            <button class="btn btn-sm btn-primary" @onclick="SaveShader"
                    disabled="@(string.IsNullOrWhiteSpace(_saveName))">Save</button>
        </div>
        @if (_savedShaders.Length > 0)
        {
            <div style="margin-top: 6px; display: flex; flex-wrap: wrap; gap: 4px; align-items: center;">
                @foreach (var name in _savedShaders)
                {
                    <div style="display: inline-flex; align-items: center; background: #1a1a2e; border: 1px solid #444; border-radius: 4px; padding: 2px 2px 2px 8px; font-size: 0.82em;">
                        <button class="btn btn-sm" style="color: #58a6ff; padding: 0 4px;" @onclick="() => LoadSavedShader(name)"
                                title="Load '@name'">@name</button>
                        <button class="btn btn-sm" style="color: #ff6b6b; padding: 0 4px; font-size: 0.9em;" @onclick="() => DeleteShader(name)"
                                title="Delete '@name'">x</button>
                    </div>
                }
            </div>
        }
        @if (_saveMessage is not null)
        {
            <div style="font-size: 0.8em; color: #88ff88; margin-top: 4px;">@_saveMessage</div>
        }
    </div>
</div>

@code {
    private string _shaderCode = "";
    private string? _compileError;
    private bool _compiled;
    private bool _autoReload = true;
    private float _fps;
    private float _mouseX, _mouseY;
    private string _saveName = "";
    private string? _saveMessage;
    private string[] _savedShaders = [];
    private GpuLoop? _loop;
    private GpuDevice? _device;
    private GpuCanvas? _canvas;
    private GpuRenderPipeline? _currentPipeline;
    private GpuBindGroup? _currentBindGroup;
    private GpuBuffer? _uniformBuffer;
    private bool _gpuReady;
    private bool _needsRecompile;
    private DateTime _lastEditTime;

    private const string VertexShader = @"
struct VertexOutput {
    @builtin(position) position: vec4f,
    @location(0) uv: vec2f,
};

@vertex
fn vs_main(@builtin(vertex_index) vi: u32) -> VertexOutput {
    var pos = array<vec2f, 3>(
        vec2f(-1.0, -1.0),
        vec2f( 3.0, -1.0),
        vec2f(-1.0,  3.0),
    );
    var output: VertexOutput;
    output.position = vec4f(pos[vi], 0.0, 1.0);
    output.uv = pos[vi] * 0.5 + 0.5;
    return output;
}
";

    private const string UniformHeader = @"
struct Globals {
    time: f32,
    _pad0: f32,
    resolution: vec2f,
    mouse: vec2f,
    _pad1: vec2f,
};

@group(0) @binding(0) var<uniform> globals: Globals;
";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var adapter = await Gpu.RequestAdapterAsync(JS);
            _device = await adapter.RequestDeviceAsync();
            _canvas = await GpuCanvas.ConfigureAsync(_device, "shader-canvas");

            _uniformBuffer = await _device.CreateBufferAsync(new BufferDescriptor
            {
                Size = 32,
                Usage = BufferUsage.Uniform | BufferUsage.CopyDest,
            });

            await JS.InvokeVoidAsync("ShaderPlayground.initDropZone", "shader-editor");
            await JS.InvokeVoidAsync("ShaderPlayground.initSnippetDrag");

            _gpuReady = true;
            _savedShaders = await JS.InvokeAsync<string[]>("ShaderPlayground.listSavedShaders");
            StateHasChanged();

            // Load default template and compile it immediately
            _shaderCode = Templates[0].Code;
            StateHasChanged();
            await CompileAndReload();
        }
        catch (Exception ex)
        {
            _compileError = $"GPU init failed: {ex.Message}";
            StateHasChanged();
        }
    }

    private void OnShaderChanged()
    {
        if (_autoReload)
        {
            _lastEditTime = DateTime.UtcNow;
            _needsRecompile = true;
        }
    }

    private async Task CompileAndReload()
    {
        if (_device is null || _canvas is null || !_gpuReady) return;

        _needsRecompile = false;
        var fullShader = VertexShader + UniformHeader + _shaderCode;

        try
        {
            var module = await _device.CreateShaderModuleAsync(fullShader);

            var pipeline = await _device.CreateRenderPipelineAsync(new RenderPipelineDescriptor
            {
                Vertex = new VertexState { Module = module, EntryPoint = "vs_main" },
                Fragment = new FragmentState
                {
                    Module = module,
                    EntryPoint = "fs_main",
                    Targets = [new ColorTargetState { Format = _canvas.Format }],
                },
            });

            var bindGroup = await _device.CreateBindGroupAsync(pipeline, 0,
            [
                new BindGroupEntry { Binding = 0, Buffer = _uniformBuffer!, Size = 32 },
            ]);

            // Dispose old resources
            if (_currentPipeline is not null) await _currentPipeline.DisposeAsync();
            if (_currentBindGroup is not null) await _currentBindGroup.DisposeAsync();

            _currentPipeline = pipeline;
            _currentBindGroup = bindGroup;
            _compileError = null;
            _compiled = true;

            // Start render loop if not already running
            if (_loop is null)
                await StartRenderLoop();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            // Extract the useful part of the error message
            var msg = ex.Message;
            // WebGPU shader errors often have the error after "Tint WGSL reader failure:" or similar
            var idx = msg.IndexOf("error:", StringComparison.OrdinalIgnoreCase);
            if (idx >= 0)
                msg = msg[idx..];

            _compileError = msg;
            _compiled = false;
            StateHasChanged();
        }
    }

    private async Task StartRenderLoop()
    {
        if (_device is null || _canvas is null) return;

        float totalTime = 0;
        var uniformBytes = new byte[32];

        _loop = await Gpu.RunLoopAsync(_device, async (frame) =>
        {
            totalTime += frame.DeltaTime;
            _fps = frame.Fps;

            // Auto-reload: debounce 500ms after last edit
            if (_autoReload && _needsRecompile && (DateTime.UtcNow - _lastEditTime).TotalMilliseconds > 500)
            {
                await CompileAndReload();
            }

            if (_currentPipeline is null || _currentBindGroup is null) return;

            // Write uniforms
            BitConverter.TryWriteBytes(uniformBytes.AsSpan(0), totalTime);
            BitConverter.TryWriteBytes(uniformBytes.AsSpan(8), 512f);
            BitConverter.TryWriteBytes(uniformBytes.AsSpan(12), 512f);
            BitConverter.TryWriteBytes(uniformBytes.AsSpan(16), _mouseX);
            BitConverter.TryWriteBytes(uniformBytes.AsSpan(20), _mouseY);

            var batch = new RenderBatch(_device);
            batch.WriteBuffer(_uniformBuffer!, uniformBytes);
            var colorView = batch.GetCurrentTextureView(_canvas);
            var pass = batch.BeginRenderPass(colorView, new GpuColor(0, 0, 0, 1));
            pass.SetPipeline(_currentPipeline);
            pass.SetBindGroup(0, _currentBindGroup);
            pass.Draw(3);
            pass.EndAndSubmit();
            await batch.FlushAsync();

            if (frame.FrameIndex % 60 == 0) StateHasChanged();
        });
    }

    private async Task InsertSnippet(string code)
    {
        await JS.InvokeVoidAsync("ShaderPlayground.insertAtCursor", "shader-editor", code);
        _shaderCode = await JS.InvokeAsync<string>("ShaderPlayground.getValue", "shader-editor");
        if (_autoReload)
        {
            _needsRecompile = true;
            _lastEditTime = DateTime.UtcNow;
        }
    }

    private async Task LoadTemplate(ShaderTemplate tmpl)
    {
        _shaderCode = tmpl.Code;
        StateHasChanged();
        await CompileAndReload();
    }

    private void OnMouseMove(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        _mouseX = (float)e.OffsetX / 512f;
        _mouseY = 1f - (float)e.OffsetY / 512f;
    }

    private async Task SaveShader()
    {
        if (string.IsNullOrWhiteSpace(_saveName)) return;
        await JS.InvokeVoidAsync("ShaderPlayground.saveShader", _saveName.Trim(), _shaderCode);
        _savedShaders = await JS.InvokeAsync<string[]>("ShaderPlayground.listSavedShaders");
        _saveMessage = $"Saved '{_saveName.Trim()}'";
        _saveName = "";
        StateHasChanged();
        _ = ClearSaveMessage();
    }

    private async Task LoadSavedShader(string name)
    {
        var code = await JS.InvokeAsync<string?>("ShaderPlayground.loadShader", name);
        if (code is not null)
        {
            _shaderCode = code;
            StateHasChanged();
            await CompileAndReload();
        }
    }

    private async Task DeleteShader(string name)
    {
        await JS.InvokeVoidAsync("ShaderPlayground.deleteShader", name);
        _savedShaders = await JS.InvokeAsync<string[]>("ShaderPlayground.listSavedShaders");
        _saveMessage = $"Deleted '{name}'";
        StateHasChanged();
        _ = ClearSaveMessage();
    }

    private async Task ClearSaveMessage()
    {
        await Task.Delay(2000);
        _saveMessage = null;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_loop is not null) await _loop.DisposeAsync();
        if (_currentPipeline is not null) await _currentPipeline.DisposeAsync();
        if (_currentBindGroup is not null) await _currentBindGroup.DisposeAsync();
        if (_uniformBuffer is not null) await _uniformBuffer.DisposeAsync();
    }

    // ---- Snippets ----
    private static readonly SnippetDef[] Snippets =
    [
        // Basics
        new("UV Color", "Color from UV coordinates",
            "    let color = vec3f(uv, 0.5);\n"),
        new("Time", "Animated sine wave",
            "    let t = sin(globals.time * 3.0) * 0.5 + 0.5;\n"),
        new("Mouse", "Distance to mouse cursor",
            "    let glow = 0.05 / length(uv - globals.mouse);\n"),
        // Shapes
        new("Circle", "SDF circle",
            "    let d = length(uv - 0.5) - 0.3;\n    let circle = 1.0 - smoothstep(0.0, 0.005, d);\n"),
        new("Box", "SDF box",
            "    let b = abs(uv - 0.5) - vec2f(0.2);\n    let box = 1.0 - smoothstep(0.0, 0.005, length(max(b, vec2f(0.0))));\n"),
        new("Ring", "SDF ring",
            "    let ring = 1.0 - smoothstep(0.0, 0.005, abs(length(uv - 0.5) - 0.3) - 0.02);\n"),
        new("Star", "5-pointed star shape",
            "    let p = uv - 0.5;\n    let a = atan2(p.y, p.x);\n    let r = length(p);\n    let star = 0.15 + 0.1 * cos(a * 5.0 + globals.time);\n    let s = 1.0 - smoothstep(star - 0.01, star, r);\n"),
        // Patterns
        new("Stripes", "Animated diagonal stripes",
            "    let stripes = sin((uv.x + uv.y) * 20.0 + globals.time * 2.0) * 0.5 + 0.5;\n"),
        new("Checker", "Checkerboard pattern",
            "    let check = step(0.5, fract(floor(uv.x * 8.0) + floor(uv.y * 8.0)) * 0.5);\n"),
        new("Grid", "Thin grid lines",
            "    let grid = step(0.95, max(fract(uv.x * 10.0), fract(uv.y * 10.0)));\n"),
        new("Dots", "Polka dot pattern",
            "    let dots = 1.0 - smoothstep(0.1, 0.12, length(fract(uv * 6.0) - 0.5));\n"),
        new("Hex", "Hexagonal tiling",
            "    let h = uv * 6.0;\n    let hx = h - vec2f(floor(h.x), floor(h.y + 0.5) - 0.5 * step(1.0, fract(h.x) + fract(h.y)));\n"),
        // Math / UV
        new("Rotate", "Rotate UVs around center",
            "    let a = globals.time;\n    let co = cos(a); let si = sin(a);\n    let ruv = mat2x2f(co, -si, si, co) * (uv - 0.5) + 0.5;\n"),
        new("Tile", "Repeat/tile UVs",
            "    let tiled = fract(uv * 4.0);\n"),
        new("Polar", "Cartesian to polar coordinates",
            "    let p = uv - 0.5;\n    let angle = atan2(p.y, p.x);\n    let radius = length(p);\n"),
        new("Remap", "Remap value range",
            "    // remap x from [a,b] to [c,d]\n    // let y = c + (x - a) * (d - c) / (b - a);\n"),
        // Noise / Randomness
        new("Hash", "Hash-based noise",
            "    let n = fract(sin(dot(floor(uv * 10.0), vec2f(12.9898, 78.233))) * 43758.5453);\n"),
        new("Smooth Noise", "Interpolated value noise",
            "    let i = floor(uv * 8.0);\n    let f = fract(uv * 8.0);\n    let t = f * f * (3.0 - 2.0 * f); // smoothstep\n"),
        // Color
        new("Mix Colors", "Blend two colors",
            "    let col = mix(vec3f(0.1, 0.3, 0.8), vec3f(0.9, 0.2, 0.1), uv.x);\n"),
        new("HSV", "Hue to RGB conversion",
            "    let hue = globals.time * 0.2 + uv.x;\n    let rgb = clamp(abs(fract(hue + vec3f(0.0, 0.333, 0.667)) * 6.0 - 3.0) - 1.0, vec3f(0.0), vec3f(1.0));\n"),
        new("Vignette", "Dark edges effect",
            "    let vig = 1.0 - length(uv - 0.5) * 1.2;\n"),
        new("Posterize", "Reduce color levels",
            "    let levels = 4.0;\n    // use: floor(color * levels) / levels\n"),
        // Effects
        new("Pixelate", "Pixelation effect",
            "    let px = 32.0;\n    let puv = floor(uv * px) / px;\n"),
        new("Wave Distort", "Wavy UV distortion",
            "    let wuv = uv + vec2f(sin(uv.y * 10.0 + globals.time) * 0.03, cos(uv.x * 10.0 + globals.time) * 0.03);\n"),
        new("Radial Blur", "Zoom blur from center",
            "    let dir = normalize(uv - 0.5) * 0.01;\n    // sample multiple offsets along dir and average\n"),
        new("Scanlines", "CRT scanline effect",
            "    let scan = sin(uv.y * globals.resolution.y * 3.14159) * 0.1 + 0.9;\n"),
    ];

    // ---- Templates ----
    private static readonly ShaderTemplate[] Templates =
    [
        new("Gradient", @"
@fragment
fn fs_main(@location(0) uv: vec2f) -> @location(0) vec4f {
    let color = vec3f(uv, sin(globals.time) * 0.5 + 0.5);
    return vec4f(color, 1.0);
}
"),
        new("Plasma", @"
@fragment
fn fs_main(@location(0) uv: vec2f) -> @location(0) vec4f {
    let t = globals.time;
    var v = 0.0;
    v += sin(uv.x * 10.0 + t);
    v += sin((uv.y * 10.0 + t) * 0.5);
    v += sin((uv.x * 10.0 + uv.y * 10.0 + t) * 0.5);
    let c = v * 0.5;
    let r = sin(c * 3.14159) * 0.5 + 0.5;
    let g = sin(c * 3.14159 + 2.094) * 0.5 + 0.5;
    let b = sin(c * 3.14159 + 4.188) * 0.5 + 0.5;
    return vec4f(r, g, b, 1.0);
}
"),
        new("Tunnel", @"
@fragment
fn fs_main(@location(0) uv: vec2f) -> @location(0) vec4f {
    let p = uv - 0.5;
    let angle = atan2(p.y, p.x);
    let radius = length(p);

    let tunnel_u = angle / 3.14159;
    let tunnel_v = 0.5 / radius + globals.time * 0.5;

    let pattern = sin(tunnel_u * 8.0) * sin(tunnel_v * 8.0);
    let c = pattern * 0.5 + 0.5;

    let fog = smoothstep(0.0, 0.5, radius);
    let color = vec3f(c * 0.3, c * 0.5 * fog, c * fog);
    return vec4f(color, 1.0);
}
"),
        new("Fractal", @"
@fragment
fn fs_main(@location(0) uv: vec2f) -> @location(0) vec4f {
