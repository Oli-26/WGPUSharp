fn hash(p: vec2f) -> f32 {
    return fract(sin(dot(p, vec2f(12.9898, 78.233))) * 43758.5453);
}

@fragment
fn fs_main(@location(0) uv: vec2f) -> @location(0) vec4f {
    let t = globals.time;
    var color = vec3f(0.02, 0.02, 0.05); // dark sky

    // Rain layers
    for (var layer = 0; layer < 3; layer++) {
        let fl = f32(layer);
        let scale = vec2f(30.0 + fl * 20.0, 5.0 + fl * 3.0);
        let speed = 3.0 + fl * 2.0;
        let brightness = 0.15 - fl * 0.03;

        var p = uv * scale;
        p.y -= t * speed;

        let cell = floor(p);
        let f = fract(p);

        let rand = hash(cell);
        if (rand > 0.6) {
            // Rain drop — elongated vertically
            let drop_x = hash(cell + 0.1);
            let dx = abs(f.x - drop_x);
            let drop_length = 0.3 + hash(cell + 0.2) * 0.5;
            let dy = f.y;

            let drop = smoothstep(0.015, 0.0, dx) * smoothstep(drop_length, 0.0, dy);
            color += vec3f(0.4, 0.5, 0.7) * drop * brightness;
        }
    }

    // Puddle ripples at bottom
    let puddle = step(0.85, uv.y);
    let ripple_p = vec2f(uv.x * 20.0, t * 2.0);
    for (var i = 0; i < 3; i++) {
        let center = vec2f(hash(vec2f(f32(i), floor(t + f32(i)))) * 20.0, fract(t + f32(i) * 0.3) * 2.0);
        let d = length(ripple_p - center);
        let ring = smoothstep(0.05, 0.0, abs(sin(d * 3.0) * 0.5) - 0.45) * 0.1;
        color += ring * puddle * vec3f(0.3, 0.4, 0.5);
    }

    return vec4f(color, 1.0);
}
