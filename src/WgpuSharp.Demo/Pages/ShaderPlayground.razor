    let water_base = mix(vec3f(0.0, 0.3, 0.5), vec3f(0.0, 0.05, 0.15), depth);
    let foam = smoothstep(0.01, 0.0, abs(p.y - horizon)) * 0.5;

    // Reflection
    let ref_wave = sin(p.x * 20.0 + t * 3.0) * 0.003;
    let reflection = 0.01 / (abs(p.x - 0.5 + ref_wave) + 0.005) * smoothstep(0.5, 0.45, p.y) * 0.05;
    let ref_color = vec3f(1.0, 0.6, 0.2) * reflection;

