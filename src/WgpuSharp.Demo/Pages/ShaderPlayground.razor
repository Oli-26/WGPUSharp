@fragment
fn fs_main(@location(0) uv: vec2f) -> @location(0) vec4f {
    let t = globals.time;
    var p = (uv - 0.5) * 4.0;

    // Domain warping
    var q = p;
    for (var i = 0; i < 4; i++) {
        q = vec2f(
            sin(q.x * 1.3 + t * 0.7 + q.y) + cos(q.y * 0.9 - t * 0.5),
            cos(q.x * 1.1 - t * 0.3) + sin(q.y * 1.4 + t * 0.6)
        );
    }

    let v = length(q) * 0.3;

    let r = sin(v + t) * 0.5 + 0.5;
    let g = sin(v * 1.3 + t * 1.1 + 2.0) * 0.5 + 0.5;
    let b = sin(v * 0.7 + t * 0.9 + 4.0) * 0.5 + 0.5;

    // Pulsing brightness
    let pulse = sin(length(p) - t * 2.0) * 0.2 + 0.8;

    return vec4f(vec3f(r, g, b) * pulse, 1.0);
}
