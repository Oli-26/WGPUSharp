fn hash(p: vec2f) -> f32 {
    return fract(sin(dot(p, vec2f(127.1, 311.7))) * 43758.5453);
}

fn noise(p: vec2f) -> f32 {
    let i = floor(p);
    let f = fract(p);
    let u = f * f * (3.0 - 2.0 * f);
    return mix(mix(hash(i), hash(i + vec2f(1.0, 0.0)), u.x),
               mix(hash(i + vec2f(0.0, 1.0)), hash(i + vec2f(1.0, 1.0)), u.x), u.y);
}

fn fbm(p: vec2f) -> f32 {
    var v = 0.0; var a = 0.5; var pos = p;
    for (var i = 0; i < 6; i++) { v += a * noise(pos); pos *= 2.02; a *= 0.5; }
    return v;
}

@fragment
fn fs_main(@location(0) uv: vec2f) -> @location(0) vec4f {
    let t = globals.time * 0.3;
    let p = uv * 3.0;

    // Domain warping — the secret to realistic smoke
    let q = vec2f(fbm(p + t * 0.4), fbm(p + vec2f(5.2, 1.3) + t * 0.3));
    let r2 = vec2f(fbm(p + q * 4.0 + vec2f(1.7, 9.2) + t * 0.2),
                   fbm(p + q * 4.0 + vec2f(8.3, 2.8) + t * 0.15));
    let f = fbm(p + r2 * 4.0);

    let color_a = vec3f(0.1, 0.1, 0.15);
    let color_b = vec3f(0.3, 0.25, 0.2);
    let color_c = vec3f(0.8, 0.6, 0.4);

    var color = mix(color_a, color_b, clamp(f * 2.0, 0.0, 1.0));
    color = mix(color, color_c, clamp(length(q) * 0.5, 0.0, 1.0));
    color *= 0.7 + f * 0.5;

    return vec4f(color, 1.0);
}
"),
