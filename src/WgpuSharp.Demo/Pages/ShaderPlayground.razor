@fragment
fn fs_main(@location(0) uv: vec2f) -> @location(0) vec4f {
    var p = uv - 0.5;
    let angle = atan2(p.y, p.x);
    let radius = length(p);

    // Mirror into 6 segments
    let segments = 6.0;
    let a = abs(((angle / 3.14159 * 0.5 + 0.5) * segments) % 2.0 - 1.0);
    let mirrored = vec2f(cos(a * 3.14159 / segments), sin(a * 3.14159 / segments)) * radius;

    let t = globals.time * 0.3;
    let pattern = sin(mirrored.x * 15.0 + t) * sin(mirrored.y * 15.0 - t);
    let pattern2 = cos(length(mirrored) * 20.0 - t * 3.0);

    let r = sin(pattern + t) * 0.5 + 0.5;
    let g = sin(pattern2 + t * 1.3) * 0.5 + 0.5;
    let b = sin(pattern + pattern2) * 0.5 + 0.5;

    let vig = 1.0 - radius * 1.5;
    return vec4f(vec3f(r, g, b) * vig, 1.0);
}
