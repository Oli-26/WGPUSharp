    let r = smoothstep(0.5, 0.48, length(fract(vec2f(p.x - split, p.y) * 8.0) - 0.5));
    let g = smoothstep(0.5, 0.48, length(fract(vec2f(p.x, p.y) * 8.0) - 0.5));
    let b = smoothstep(0.5, 0.48, length(fract(vec2f(p.x + split, p.y) * 8.0) - 0.5));

    // Scanlines
    let scan = sin(p.y * 400.0) * 0.04 + 0.96;

    // Base pattern (something to glitch)
    let pattern = sin(p.x * 10.0 + t) * sin(p.y * 10.0 + t * 0.7) * 0.5 + 0.5;
    var color = vec3f(r + pattern * 0.3, g + pattern * 0.5, b + pattern * 0.8);

    // White noise flash
    let noise_flash = step(0.95, hash(vec2f(floor(t * 15.0)))) * hash(floor(p * 100.0)) * 0.3;
    color += noise_flash;

    return vec4f(color * scan, 1.0);
}
