@fragment
fn fs_main(@location(0) uv: vec2f) -> @location(0) vec4f {
    let t = globals.time;
    let p = (uv - 0.5) * 2.0;
    let r = length(p);

    // Only draw inside the ball
    if (r > 0.8) {
        // Background rays
        let a = atan2(p.y, p.x);
        let ray = pow(abs(sin(a * 6.0 + t * 2.0)), 8.0) * 0.15 / (r * 0.5);
        return vec4f(vec3f(ray) * vec3f(0.3, 0.1, 0.5), 1.0);
    }

    // Fake sphere UV mapping
    let z = sqrt(max(0.0, 1.0 - p.x * p.x - p.y * p.y));
    let sphere_a = atan2(p.x, z) + t * 0.5;
    let sphere_b = asin(p.y / 1.0);

    // Mirror tile grid
    let tile_a = floor(sphere_a * 8.0);
    let tile_b = floor(sphere_b * 6.0);
    let tile_edge_a = abs(fract(sphere_a * 8.0) - 0.5);
    let tile_edge_b = abs(fract(sphere_b * 6.0) - 0.5);
    let edge = smoothstep(0.45, 0.5, max(tile_edge_a, tile_edge_b));

    // Each tile reflects a different color
    let hue = fract(tile_a * 0.17 + tile_b * 0.31 + t * 0.2);
    let tile_color = clamp(abs(fract(hue + vec3f(0.0, 0.333, 0.667)) * 6.0 - 3.0) - 1.0, vec3f(0.0), vec3f(1.0));

    // Specular highlight
    let spec = pow(max(z, 0.0), 20.0) * 0.5;

    // Fresnel-ish rim
    let rim = pow(1.0 - z, 3.0) * 0.3;

    let color = tile_color * (1.0 - edge) * 0.7 + edge * 0.15 + spec + rim;
    return vec4f(color, 1.0);
}
