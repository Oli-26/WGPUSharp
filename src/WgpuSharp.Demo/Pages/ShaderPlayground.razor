fn hash2(p: vec2f) -> vec2f {
    return fract(sin(vec2f(dot(p, vec2f(127.1, 311.7)),
                           dot(p, vec2f(269.5, 183.3)))) * 43758.5453);
}

@fragment
fn fs_main(@location(0) uv: vec2f) -> @location(0) vec4f {
    let t = globals.time * 0.5;
    let scale = 6.0;
    let p = uv * scale;
    let ip = floor(p);
    let fp = fract(p);

    var d1 = 1.0;
    var d2 = 1.0;

    for (var y = -1; y <= 1; y++) {
        for (var x = -1; x <= 1; x++) {
            let neighbor = vec2f(f32(x), f32(y));
            let pt = hash2(ip + neighbor);
            let animated = 0.5 + 0.5 * sin(t * 1.5 + pt * 6.28);
            let diff = neighbor + animated - fp;
            let d = dot(diff, diff);
            if (d < d1) { d2 = d1; d1 = d; }
            else if (d < d2) { d2 = d; }
        }
    }

    let edge = d2 - d1;
    let cell_wall = smoothstep(0.0, 0.08, edge);

    // Organic coloring
    let nucleus = smoothstep(0.08, 0.02, d1);
    let cytoplasm = smoothstep(0.5, 0.1, d1);

    let wall_color = vec3f(0.1, 0.6, 0.3);
    let cell_color = vec3f(0.05, 0.2, 0.1) + nucleus * vec3f(0.3, 0.1, 0.0);
    let membrane = (1.0 - cell_wall) * vec3f(0.0, 0.8, 0.4);

    let color = cell_color * cytoplasm + membrane;
    return vec4f(color, 1.0);
}
