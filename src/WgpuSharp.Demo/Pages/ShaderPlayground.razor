fn hash2(p: vec2f) -> vec2f {
    return fract(sin(vec2f(dot(p, vec2f(127.1, 311.7)),
                           dot(p, vec2f(269.5, 183.3)))) * 43758.5453);
}

@fragment
fn fs_main(@location(0) uv: vec2f) -> @location(0) vec4f {
    let scale = 5.0;
    let p = uv * scale;
    let ip = floor(p);
    let fp = fract(p);

    var minDist = 1.0;
    var cellColor = vec2f(0.0);

    for (var y = -1; y <= 1; y++) {
        for (var x = -1; x <= 1; x++) {
            let neighbor = vec2f(f32(x), f32(y));
            let point = hash2(ip + neighbor);
            let animated = 0.5 + 0.5 * sin(globals.time + point * 6.28);
            let d = length(neighbor + animated - fp);
            if (d < minDist) {
                minDist = d;
                cellColor = point;
            }
        }
    }

    let edge = smoothstep(0.0, 0.05, minDist);
    let hue = cellColor.x;
    let rgb = clamp(abs(fract(hue + vec3f(0.0, 0.333, 0.667)) * 6.0 - 3.0) - 1.0, vec3f(0.0), vec3f(1.0));
    return vec4f(rgb * edge * 0.8, 1.0);
}
